# Emerge Digital — Vision hub environment variables
#
# Copy to `.env` for local dev, or set these in Cloudflare Pages →
# Settings → Environment variables for production. Only `PUBLIC_`-prefixed
# vars are exposed to the client bundle at build time.

# Cloudflare Web Analytics beacon token (Cloudflare dashboard → Web Analytics).
# When unset, BaseLayout falls back to a clearly-marked placeholder so the
# beacon markup is still reviewable in a PR.
PUBLIC_CF_BEACON_TOKEN=CF_BEACON_TOKEN_PLACEHOLDER

# Outbound funnel destinations (see src/lib/outbound.ts). Override the
# placeholder origins once the production roai / future URLs are confirmed.
PUBLIC_ROAI_URL=https://roai.emergedigital.ae
PUBLIC_FUTURE_URL=https://future.emergedigital.ae
