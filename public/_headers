# Cloudflare static-asset headers (honoured by the Workers ASSETS binding).
# Content-hashed Astro bundles never change for a given URL — cache immutably.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts are also fingerprinted and safe to cache hard.
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
