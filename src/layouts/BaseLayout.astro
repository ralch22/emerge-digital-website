---
/**
 * BaseLayout — master document scaffold for every page.
 * Pages should pass `title`, `description`, and optionally `ogImage`.
 *
 * Header and Footer are placeholders — Claude Code will build them
 * out in Prompt 01 / 02. They are intentionally minimal here so the
 * scaffold is runnable from the first `npm run dev`.
 */
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation across MEA.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon (placeholder — add real favicons in /public) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color matches the brand navy -->
    <meta name="theme-color" content="#0A1F3D" />
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-pill focus:bg-teal focus:px-4 focus:py-2 focus:text-ink"
    >
      Skip to content
    </a>

    <header class="border-b border-white/5">
      <div class="mx-auto flex max-w-section items-center justify-between px-6 py-5">
        <a href="/" class="font-display text-lg font-semibold tracking-tight text-white">
          Emerge<span class="text-teal">.</span>
        </a>
        <nav aria-label="Primary" class="hidden items-center gap-8 text-sm text-platinum/80 md:flex">
          <a href="/services/" class="hover:text-white">Services</a>
          <a href="/industries/" class="hover:text-white">Industries</a>
          <a href="/partnerships/" class="hover:text-white">Partnerships</a>
          <a href="/success-stories/" class="hover:text-white">Success Stories</a>
          <a href="/insights/" class="hover:text-white">Insights</a>
          <a href="/about/" class="hover:text-white">About</a>
        </nav>
        <a
          href="/contact/"
          class="rounded-pill bg-gradient-accent px-5 py-2.5 text-sm font-semibold text-ink transition hover:shadow-glow"
        >
          Book a Briefing →
        </a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-ink">
      <div class="mx-auto max-w-section px-6 py-16 text-sm text-cool">
        <div class="grid gap-10 md:grid-cols-4">
          <div>
            <a href="/" class="font-display text-lg font-semibold tracking-tight text-white">
              Emerge<span class="text-teal">.</span>
            </a>
            <p class="mt-3 max-w-xs">
              Local prime. Global power. Enterprise outcomes across the MEA region.
            </p>
          </div>
          <div>
            <h4 class="text-white/90 font-semibold">Company</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/about/" class="hover:text-white">About</a></li>
              <li><a href="/partnerships/" class="hover:text-white">Partnerships</a></li>
              <li><a href="/contact/" class="hover:text-white">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white/90 font-semibold">Capabilities</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/services/" class="hover:text-white">Services</a></li>
              <li><a href="/industries/" class="hover:text-white">Industries</a></li>
              <li><a href="/success-stories/" class="hover:text-white">Success Stories</a></li>
              <li><a href="/insights/" class="hover:text-white">Insights</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white/90 font-semibold">Compliance</h4>
            <p class="mt-3">
              Emerge Digital — Dubai Mainland Licence No. [XXXXX] · Registered Office: [Address] · ESR & UBO Compliant.
            </p>
          </div>
        </div>
        <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/5 pt-6 md:flex-row md:items-center">
          <p>© {new Date().getFullYear()} Emerge Digital. All rights reserved.</p>
          <ul class="flex gap-6">
            <li><a href="/legal/privacy/" class="hover:text-white">Privacy</a></li>
            <li><a href="/legal/cookies/" class="hover:text-white">Cookies</a></li>
            <li><a href="/legal/terms/" class="hover:text-white">Terms</a></li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
