---
/**
 * BaseLayout — master document scaffold for every page.
 * Pages should pass `title`, `description`, and optionally `ogImage`.
 */
import '../styles/global.css';
// LCP web-font preload — fingerprinted URL for the latin Lexend subset (text-LCP font).
import lexendLatinWoff2 from '@fontsource-variable/lexend/files/lexend-latin-wght-normal.woff2?url';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation across MEA.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://emerge-digital-website.emerge-digital.workers.dev').toString();

// Organization + WebSite JSON-LD — corporate-hub structured data for every page.
const siteBase = (Astro.site ?? new URL('https://vision.emergedigital.ae')).toString().replace(/\/$/, '');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteBase}/#organization`,
      name: 'Emerge Digital',
      url: `${siteBase}/`,
      logo: `${siteBase}/favicon.svg`,
      description:
        'The Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation across the MEA region.',
      areaServed: ['AE', 'SA', 'EG', 'Middle East & Africa'],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteBase}/#website`,
      name: 'Emerge Digital',
      url: `${siteBase}/`,
      publisher: { '@id': `${siteBase}/#organization` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- LCP web-font preload — latin Lexend subset, discovered before CSS parse -->
    <link rel="preload" href={lexendLatinWoff2} as="font" type="font/woff2" crossorigin />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, canonical).toString()} />
    <meta property="og:site_name" content="Emerge Digital" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0A1F3D" />

    <!-- Google tag (gtag.js) — GA4 stream Vision Site · vision.emergedigital.ae -->
    <!-- Loaded after title/meta/CSS so it stays out of the critical render path; `async` keeps it non-blocking. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HEQYW1EESD"></script>
    <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-HEQYW1EESD');</script>
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-pill focus:bg-teal focus:px-4 focus:py-2 focus:text-ink"
    >
      Skip to content
    </a>

    <Navbar />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- Scroll-reveal: IntersectionObserver wires [data-reveal] → .is-visible -->
    <script>
      (() => {
        // Bail if the user prefers reduced motion — CSS already forces visible
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');
        if (!targets.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target); // animate once
              }
            });
          },
          {
            // Trigger when element is 80px from the bottom of the viewport
            rootMargin: '0px 0px -80px 0px',
            threshold: 0.01,
          },
        );

        targets.forEach((el) => observer.observe(el));
      })();
    </script>

    <!-- Lenis smooth scroll — initialised at end of body so DOM is ready. -->
    <script>
      import Lenis from 'lenis';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduced) {
        const lenis = new Lenis({
          duration: 1.15,
          // Smooth easing — ease-out-expo
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          wheelMultiplier: 1,
          touchMultiplier: 1.4,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Anchor links — smooth scroll handled by Lenis automatically.
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (target) {
              e.preventDefault();
              lenis.scrollTo(target as HTMLElement, { offset: -80 });
            }
          });
        });
      }
    </script>
  </body>
</html>
