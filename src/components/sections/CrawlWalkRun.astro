---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const steps = [
  {
    label: 'Crawl',
    duration: '4–8 weeks',
    risk: 'Low risk',
    body: 'A focused, fixed-scope diagnostic. Maturity assessment, opportunity sizing, business case, and a Vision 2030-aligned roadmap. Low-risk, high-clarity — built so procurement can sign in days, not months.',
    color: 'from-teal/20 to-teal/5',
  },
  {
    label: 'Walk',
    duration: '3–6 months',
    risk: 'Defined gates',
    body: 'A defined transformation phase against a prioritised opportunity (CDP rollout, CX redesign, analytics governance rebuild). Clear gates, clear KPIs, founder-level oversight throughout.',
    color: 'from-cyan/20 to-cyan/5',
  },
  {
    label: 'Run',
    duration: '12+ months',
    risk: 'Long-term program',
    body: 'A long-term, multi-workstream program managed through the local prime, with our managed-services bench providing run-state operations, AI ops, and continuous modernisation.',
    color: 'from-teal-glow/20 to-teal-glow/5',
  },
];
---

<Section tone="dark" class="relative isolate overflow-hidden">
  <div aria-hidden="true" class="cwr-grid pointer-events-none absolute inset-0"></div>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(0,194,199,0.05), transparent 70%); filter: blur(60px);"
  ></div>

  <Container class="relative">
    <div class="max-w-3xl">
      <Eyebrow data-reveal>How We Engage</Eyebrow>
      <h2 class="mt-4 text-display-lg" data-reveal data-reveal-delay="1">
        A risk-managed path from
        <span class="text-gradient-accent">ambition to enterprise outcome.</span>
      </h2>
    </div>

    <!-- Connector track -->
    <div class="mt-16 relative">
      <!-- Horizontal connector line (desktop) -->
      <div
        aria-hidden="true"
        class="absolute left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] top-8 hidden h-px lg:block"
        style="background: linear-gradient(90deg, transparent, rgba(0,194,199,0.3), rgba(61,220,227,0.5), rgba(0,194,199,0.3), transparent);"
      ></div>

      <ol class="grid gap-8 lg:grid-cols-3 lg:gap-6">
        {steps.map((s, i) => (
          <li
            class="cwr-step group relative rounded-card border border-white/8 p-8 transition-all duration-400 hover:border-teal/35 hover:shadow-card-hover hover:-translate-y-1"
            style="background: rgba(255,255,255,0.025); backdrop-filter: blur(12px);"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <!-- Step badge -->
            <div class="relative mb-6 flex h-[3.5rem] w-[3.5rem] items-center justify-center rounded-full bg-gradient-accent text-sm font-mono font-bold text-ink shadow-glow">
              {String(i + 1).padStart(2, '0')}
              <!-- Ping ring -->
              <div
                class="absolute inset-0 rounded-full bg-teal/20"
                style={`animation: ping-slow ${3 + i * 0.5}s ease-in-out ${i * 0.8}s infinite;`}
              ></div>
            </div>

            <!-- Step info -->
            <div class="mb-4 flex items-center gap-3">
              <h3 class="text-display-md text-teal">{s.label}</h3>
              <span class="rounded-pill border border-white/10 bg-white/5 px-2.5 py-0.5 font-mono text-[10px] text-cool">{s.duration}</span>
            </div>

            <p class="text-sm leading-relaxed text-platinum/70 transition-colors duration-300 group-hover:text-platinum/90">
              {s.body}
            </p>

            <!-- Risk label -->
            <div class="mt-5 flex items-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-teal/60"></div>
              <span class="text-[10px] font-semibold uppercase tracking-eyebrow text-cool">{s.risk}</span>
            </div>

            <!-- Connector arrow (desktop, not last item) -->
            {i < steps.length - 1 && (
              <div aria-hidden="true" class="absolute -right-3.5 top-8 z-10 hidden h-7 w-7 items-center justify-center rounded-full border border-teal/30 bg-ink lg:flex">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="text-teal">
                  <path d="M2 5h6M6 3l2 2-2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </li>
        ))}
      </ol>
    </div>

    <div class="mt-12">
      <Button href="/contact/">Start with a Crawl-phase Diagnostic</Button>
    </div>
  </Container>
</Section>

<style>
  .cwr-grid {
    background-image: linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 96px 100%;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black, transparent 80%);
  }
  @keyframes ping-slow {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50%       { transform: scale(1.7); opacity: 0; }
  }
</style>
