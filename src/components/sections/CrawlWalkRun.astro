---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const steps = [
  {
    label: 'Crawl',
    duration: '4–8 weeks',
    body:
      'A focused, fixed-scope diagnostic. Maturity assessment, opportunity sizing, business case, and a Vision 2030-aligned roadmap. Low-risk, high-clarity — built so procurement can sign in days, not months.',
  },
  {
    label: 'Walk',
    duration: '3–6 months',
    body:
      'A defined transformation phase against a prioritized opportunity (e.g., a CDP rollout, a CX redesign, an analytics governance rebuild). Clear gates, clear KPIs, founder-level oversight.',
  },
  {
    label: 'Run',
    duration: '12+ months',
    body:
      "A long-term, multi-workstream program managed through the local prime, with FPT's managed-services bench providing run-state operations, AI ops, and continuous modernization.",
  },
];
---

<Section tone="dark">
  <Container>
    <div class="max-w-3xl">
      <Eyebrow>How We Engage</Eyebrow>
      <h2 class="mt-4 text-display-lg">A risk-managed path from ambition to enterprise outcome.</h2>
    </div>

    <div class="mt-16">
      <svg
        viewBox="0 0 900 80"
        class="hidden w-full lg:block"
        role="presentation"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="cwr-line" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="var(--color-navy)" />
            <stop offset="50%" stop-color="var(--color-teal)" stop-opacity="0.85" />
            <stop offset="100%" stop-color="var(--color-cyan)" />
          </linearGradient>
          <radialGradient id="cwr-node" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="var(--color-cyan)" />
            <stop offset="100%" stop-color="var(--color-teal)" />
          </radialGradient>
        </defs>
        <line x1="60" y1="40" x2="840" y2="40" stroke="url(#cwr-line)" stroke-width="2" />
        <g>
          <circle cx="150" cy="40" r="14" fill="var(--color-ink)" stroke="var(--color-teal)" stroke-width="2" />
          <circle cx="150" cy="40" r="5" fill="var(--color-teal)" />
        </g>
        <g>
          <circle cx="450" cy="40" r="18" fill="var(--color-ink)" stroke="var(--color-teal)" stroke-width="2" />
          <circle cx="450" cy="40" r="7" fill="url(#cwr-node)" />
        </g>
        <g>
          <circle cx="750" cy="40" r="22" fill="var(--color-ink)" stroke="var(--color-cyan)" stroke-width="2" />
          <circle cx="750" cy="40" r="10" fill="url(#cwr-node)" />
        </g>
      </svg>

      <ol class="mt-6 grid gap-8 lg:grid-cols-3 lg:gap-12">
        {
          steps.map((s, i) => (
            <li class="rounded-card border border-white/10 bg-navy/40 p-8 lg:bg-transparent lg:p-0">
              <p class="font-mono text-eyebrow uppercase text-cool">Step {i + 1}</p>
              <div class="mt-3 flex items-baseline gap-3">
                <h3 class="text-display-md text-teal">{s.label}</h3>
                <span class="font-mono text-sm text-cool">{s.duration}</span>
              </div>
              <p class="mt-4 text-platinum/80">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="mt-12">
      <Button href="/contact/">Start with a Crawl phase</Button>
    </div>
  </Container>
</Section>
