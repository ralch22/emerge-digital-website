---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const steps = [
  {
    label: 'Crawl',
    duration: '4–8 weeks',
    body:
      'A focused, fixed-scope diagnostic. Maturity assessment, opportunity sizing, business case, and a Vision 2030-aligned roadmap. Low-risk, high-clarity — built so procurement can sign in days, not months.',
  },
  {
    label: 'Walk',
    duration: '3–6 months',
    body:
      'A defined transformation phase against a prioritized opportunity (e.g., a CDP rollout, a CX redesign, an analytics governance rebuild). Clear gates, clear KPIs, founder-level oversight.',
  },
  {
    label: 'Run',
    duration: '12+ months',
    body:
      'A long-term, multi-workstream program managed through the local prime, with our managed-services bench providing run-state operations, AI ops, and continuous modernization.',
  },
];
---

<Section tone="dark" class="relative isolate overflow-hidden">
  <div aria-hidden="true" class="cwr-grid pointer-events-none absolute inset-0"></div>
  <Container class="relative">
    <div class="max-w-3xl">
      <Eyebrow data-reveal>How We Engage</Eyebrow>
      <h2 class="mt-4 text-display-lg" data-reveal data-reveal-delay="1">A risk-managed path from ambition to enterprise outcome.</h2>
    </div>

    <div class="mt-16">
      <ol class="cwr-track grid gap-8 lg:grid-cols-3 lg:gap-6">
        {
          steps.map((s, i) => (
            <li class="cwr-step relative rounded-card border border-white/10 bg-navy/40 p-8 backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:border-teal/40" data-reveal data-reveal-delay={String(i + 1)}>
              <div aria-hidden="true" class="cwr-node absolute -top-4 left-8 inline-flex h-8 w-8 items-center justify-center rounded-full bg-gradient-accent text-xs font-mono font-bold text-ink shadow-glow">
                {String(i + 1).padStart(2, '0')}
              </div>
              <div class="mt-3 flex items-baseline gap-3">
                <h3 class="text-display-md text-teal">{s.label}</h3>
                <span class="font-mono text-sm text-cool">{s.duration}</span>
              </div>
              <p class="mt-4 text-platinum/80">{s.body}</p>
              {i < steps.length - 1 && (
                <span aria-hidden="true" class="cwr-connector hidden lg:block" />
              )}
            </li>
          ))
        }
      </ol>
    </div>

    <div class="mt-12">
      <Button href="/contact/">Start with a Crawl phase</Button>
    </div>
  </Container>
</Section>

<style>
  .cwr-grid {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 96px 100%;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black, transparent 80%);
  }
  .cwr-connector {
    position: absolute;
    top: 50%;
    right: -1.6rem;
    width: 1.6rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(0, 194, 199, 0.5), rgba(61, 220, 227, 0.05));
  }
  .cwr-step:hover .cwr-node {
    transform: scale(1.08);
    transition: transform 0.25s ease;
  }
</style>
