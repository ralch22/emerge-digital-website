    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }
  .hero-mobile-trust {
    margin-top: 3rem;
  }

  /* Trigger: mobile width OR reduced motion */
  @media (max-width: 768px), (prefers-reduced-motion: reduce) {
    /* Disable the cinematic stage entirely */
    .hero-section { height: auto; margin-top: 0; }
    .hero-sticky  { position: relative; height: auto; overflow: visible; }
    .letters-wrap, .bottom-bar-outer { display: none; }
    .hero-mobile  { display: block; position: relative; isolation: isolate; }

    /* Suppress non-essential animations under reduced motion */
    .aurora-layer-1, .aurora-layer-2, .aurora-layer-3,
    .marquee-track, .beam-scan::after { animation: none; }
  }
  @media (max-width: 768px) {
    /* Mobile-only refinements */
    .hero-mobile-ctas { flex-direction: column; align-items: stretch; }
    .hero-mobile-headline { font-size: clamp(1.875rem, 7.5vw, 2.5rem); }
  }
</style>

<script>
  const reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  /* ── Scroll-driven cinematic O-reveal (desktop / tablet only) ──
   * Progress is derived explicitly from the hero's own scroll position and
   * clamped to [0, 1]. This guarantees the resting state at the top of the
   * page is progress 0 — "VISION" fully on-screen — instead of relying on a
   * scroll-library offset that could resolve mid-animation on load and drag
   * the leftmost "V" off the left edge. */
  if (!reduced && !isMobile) {
    const heroSection = document.querySelector<HTMLElement>('[data-hero]');
    const oFrame      = document.querySelector<HTMLElement>('[data-o-frame]');
    const oInner      = document.querySelector<HTMLElement>('[data-o-inner]');
    const oRing       = document.querySelector<HTMLElement>('[data-o-ring]');
    const oStack      = document.querySelector<HTMLElement>('[data-o-inner-stack]');
    const letters     = Array.from(document.querySelectorAll<HTMLElement>('[data-letter]'));

    if (heroSection && oFrame && oRing && oStack) {
      const lerp  = (a: number, b: number, t: number) => a + (b - a) * t;
      const clamp = (v: number) => (v < 0 ? 0 : v > 1 ? 1 : v);

      let ticking = false;
      const render = () => {
        ticking = false;
        const total = heroSection.offsetHeight - window.innerHeight; // scrubbable distance
        const p = total > 0 ? clamp(-heroSection.getBoundingClientRect().top / total) : 0;

        /* O frame expands to fill the viewport */
        oFrame.style.width        = `${lerp(38, 100, p)}vw`;
        oFrame.style.height       = `${lerp(32, 100, p)}vh`;
        oFrame.style.borderRadius = `${lerp(9999, 0, p)}px`;
        oFrame.style.margin       = `0 ${lerp(0.6, 0, p)}vw`;
        if (oInner) oInner.style.borderRadius = `${lerp(9999, 0, p)}px`;

        /* Ring holds, then fades + thins over the final half */
        const ringP = clamp((p - 0.5) / 0.5);
        oRing.style.opacity     = `${1 - ringP}`;
        oRing.style.borderWidth = `${lerp(3, 0, ringP)}px`;

        /* Letters scatter outward and fade out over the final ~60% */
        const fade = clamp((p - 0.4) / 0.6);
        letters.forEach((l) => {
          const pos = parseFloat(l.dataset.pos ?? '0');
          l.style.transform = `translateX(${pos * 14 * p}vw)`;
          l.style.opacity   = `${1 - fade}`;
        });

        /* Content stack scales up + sharpens over the first ~60% */
        const sp = clamp(p / 0.6);
        oStack.style.transform = `scale(${lerp(0.65, 1, sp)})`;
        oStack.style.opacity   = `${lerp(0.7, 1, sp)}`;
      };

      const onScroll = () => {
        if (!ticking) { ticking = true; requestAnimationFrame(render); }
      };
      render();                                              // set progress-0 state on load
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', render);
    }
  }

  /* ── Mouse-tracked card glow (carry-over for downstream sections) ── */
  if (!reduced) {
    document.querySelectorAll<HTMLElement>('.service-card-premium, .tilt-card').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${((e.clientX - rect.left) / rect.width) * 100}%`);
        card.style.setProperty('--my', `${((e.clientY - rect.top)  / rect.height) * 100}%`);
      });
    });
  }
</script>
