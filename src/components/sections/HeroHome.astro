---
/**
 * HeroHome — Arooth-style "VISION" letter-frame hero.
 *
 * The signature Arooth pattern, adapted for Emerge Digital:
 *
 *   V · I · S · I · O · N    (six massive letters span the screen)
 *
 *   The "O" is not a letter — it is a circular viewport that frames
 *   the hero content (eyebrow, headline, CTA, marquee). Small at the
 *   start; expands to fill the entire screen as the user scrolls.
 *
 *   Sticky-pinned for 200 vh of scroll runway. Letters V·I·S·I drift
 *   left, N drifts right, all fading as the O expands. Inside the O,
 *   content scales up from a teaser into full-size hero.
 *
 *   Mobile (≤ 768 px): the sticky/letter mechanic disables completely.
 *   A clean stacked layout takes over with a static "VISION 2030"
 *   wordmark, the headline, sub, and CTAs.
 */

import Container from '../Container.astro';
import Button from '../Button.astro';
import TrustStrip from '../TrustStrip.astro';

// Months remaining in the Vision 2030 procurement window (through Dec 2027)
const now      = new Date();
const windowEnd = new Date('2027-12-31T00:00:00Z');
const monthsRemaining = Math.max(0, Math.round(
  (windowEnd.getTime() - now.getTime()) / (1000 * 60 * 60 * 24 * 30.44)
));

// Marquee phrases — alternating italic / bold / mark like Arooth
const marqueeChunks = [
  { text: 'Local Prime',         style: 'bold' },
  { text: '✦',                   style: 'star' },
  { text: 'Global Power',        style: 'mark' },
  { text: '✦',                   style: 'star' },
  { text: 'Vision 2030',         style: 'italic' },
  { text: '✦',                   style: 'star' },
  { text: 'Enterprise Outcomes', style: 'bold' },
  { text: '✦',                   style: 'star' },
  { text: 'Dubai Mainland',      style: 'mark' },
  { text: '✦',                   style: 'star' },
];
---

<section data-hero class="hero-section relative">

  <!-- Sticky stage — pins for the full scroll runway -->
  <div data-hero-sticky class="hero-sticky">
    <div data-hero-wrapper class="hero-wrapper">

      <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
      <!--                  V I S I O N                       -->
      <!--   Three-column grid locks the O to viewport center -->
      <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
      <div data-letters class="letters-wrap">
        <!-- Left letter group · pushed right by 1fr column, justified to its right edge -->
        <div data-letters-left class="letters-side letters-left">
          <span data-letter data-side="left" data-pos="-4" class="letter">V</span>
          <span data-letter data-side="left" data-pos="-3" class="letter">I</span>
          <span data-letter data-side="left" data-pos="-2" class="letter">S</span>
          <span data-letter data-side="left" data-pos="-1" class="letter">I</span>
        </div>

        <!-- Centered O frame — auto-sized grid column → always at viewport center -->
        <div data-o-frame class="o-frame">
            <div data-o-inner class="o-inner">
              <!-- Content layer: full viewport, clipped by the O -->
              <div data-o-content class="o-content">

                <!-- Backdrop layers -->
                <div aria-hidden="true" class="absolute inset-0 bg-gradient-hero-premium"></div>
                <div aria-hidden="true" class="aurora-layer-1 pointer-events-none absolute inset-0"></div>
                <div aria-hidden="true" class="aurora-layer-2 pointer-events-none absolute inset-0"></div>
                <div aria-hidden="true" class="aurora-layer-3 pointer-events-none absolute inset-0"></div>
                <div aria-hidden="true" class="bg-grid bg-grid-fade pointer-events-none absolute inset-0 opacity-50"></div>
                <div aria-hidden="true" class="noise pointer-events-none absolute inset-0"></div>
                <div aria-hidden="true" class="beam-scan absolute inset-0"></div>

                <!-- Mini Dubai skyline at bottom -->
                <div aria-hidden="true" class="dubai-skyline-mini">
                  <svg viewBox="0 0 1440 220" preserveAspectRatio="xMidYMax slice" class="h-full w-full" fill="none">
                    <defs>
                      <linearGradient id="hero-skyline-fade" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%"   stop-color="#00C2C7" stop-opacity="0.10"/>
                        <stop offset="100%" stop-color="#00C2C7" stop-opacity="0.02"/>
                      </linearGradient>
                      <linearGradient id="hero-skyline-h-fade" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%"   stop-color="white" stop-opacity="0"/>
                        <stop offset="14%"  stop-color="white" stop-opacity="1"/>
                        <stop offset="86%"  stop-color="white" stop-opacity="1"/>
                        <stop offset="100%" stop-color="white" stop-opacity="0"/>
                      </linearGradient>
                      <mask id="hero-skyline-mask">
                        <rect width="1440" height="220" fill="url(#hero-skyline-h-fade)"/>
                      </mask>
                    </defs>
                    <g fill="url(#hero-skyline-fade)" mask="url(#hero-skyline-mask)">
                      <path d="M697 0 L699 44 L701 82 L703 112 L705 132 L707 152 L709 166 L711 178 L713 190 L717 202 L722 220 L678 220 L682 202 L687 190 L689 178 L691 166 L693 152 L695 132 L697 112 L699 82 Z"/>
                      <rect x="618" y="55" width="20" height="165" rx="2"/>
                      <rect x="634" y="42" width="13" height="178" rx="1"/>
                      <path d="M508 68 L510 68 L511 82 L512 220 L504 220 L505 82 Z"/>
                      <path d="M522 84 L524 84 L525 96 L526 220 L518 220 L519 96 Z"/>
                      <rect x="758"  y="76"  width="22" height="144" rx="2"/>
                      <rect x="796"  y="92"  width="17" height="128" rx="1"/>
                      <rect x="828"  y="62"  width="18" height="158" rx="1"/>
                      <rect x="862"  y="108" width="14" height="112" rx="1"/>
                      <rect x="342"  y="92"  width="20" height="128" rx="2"/>
                      <rect x="378"  y="78"  width="16" height="142" rx="2"/>
                      <rect x="412"  y="104" width="15" height="116" rx="1"/>
                      <rect x="448"  y="118" width="18" height="102" rx="1"/>
                      <rect x="958"  y="98"  width="22" height="122" rx="2"/>
                      <rect x="996"  y="118" width="16" height="102" rx="1"/>
                      <rect x="1036" y="82"  width="20" height="138" rx="2"/>
                      <rect x="1074" y="112" width="14" height="108" rx="1"/>
                      <rect x="1106" y="88"  width="18" height="132" rx="2"/>
                      <rect x="148"  y="118" width="16" height="102" rx="1"/>
                      <rect x="180"  y="102" width="20" height="118" rx="2"/>
                      <rect x="218"  y="128" width="14" height="92"  rx="1"/>
                      <rect x="252"  y="108" width="18" height="112" rx="1"/>
                      <rect x="0"    y="182" width="130"  height="38"/>
                      <rect x="108"  y="172" width="160"  height="48"/>
                      <rect x="1310" y="172" width="130"  height="48"/>
                      <rect x="1200" y="185" width="244"  height="35"/>
                      <rect x="0"    y="205" width="1440" height="15"/>
                    </g>
                  </svg>
                </div>

                <!-- Centered content stack — grid 1fr/auto/1fr keeps H1 at exact viewport center -->
                <div data-o-inner-stack class="o-inner-stack">
                  <!-- Top row · eyebrow sits flush against headline's top edge -->
                  <p class="stack-eyebrow chip-eyebrow-teal">
                    <span class="pulse-dot" aria-hidden="true"></span>
                    <span>Vision 2030 · {monthsRemaining} months remain in the procurement window</span>
                  </p>

                  <!-- Center row · headline anchors precisely at viewport vertical center.
                       Rendered as a styled paragraph, not a heading: this desktop stage
                       and the mobile stack are both in the DOM, so only one may own the
                       page's single H1. Google indexes mobile-first, so that H1 lives on
                       the mobile layout (.hero-mobile-headline) — the DOM the crawler
                       renders at a phone viewport. -->
                  <p class="stack-h1 hero-headline">
                    Local Prime. Global Power.<br/>
                    <span class="text-gradient-glow">Enterprise Outcomes.</span>
                  </p>

                  <!-- Bottom row · sub-headline + CTAs flush below headline -->
                  <div class="stack-extras">
                    <p class="hero-sub">
                      The agile <strong class="text-platinum">Dubai Mainland</strong> prime for enterprise
                      CX, Data, AI, and digital transformation across MEA — channelling 23 years of
                      regional heritage and a global group of 80,000+ through one accountable contract.
                    </p>
                    <div class="cta-row">
                      <Button href="/contact/" size="lg" class="btn-shimmer">
                        Book a Vision 2030 Readiness Briefing
                      </Button>
                      <Button variant="ghost" href="/services/" size="lg">
                        Explore the Capability Stack
                      </Button>
                    </div>
                  </div>
                </div>

                <!-- Marquee bar at bottom -->
                <div class="marquee-bar" aria-hidden="true">
                  <div class="marquee-track">
                    {Array.from({ length: 4 }, () => marqueeChunks).flat().map((c, i) => (
                      <span class:list={['marquee-chunk', `marquee-chunk--${c.style}`]}>{c.text}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- O ring border (teal glow) -->
            <div data-o-ring aria-hidden="true" class="o-ring"></div>
          </div>

        <!-- Right letter group · pushed left by 1fr column, justified to its left edge -->
        <div data-letters-right class="letters-side letters-right">
          <span data-letter data-side="right" data-pos="+1" class="letter">N</span>
        </div>
      </div>

      <!-- ░░ Bottom row — plain div (Container would lose Astro scoped CSS) ░░ -->
      <div class="bottom-bar-outer">
        <div data-bottom-bar class="bottom-bar mx-auto max-w-section px-6 sm:px-8 lg:px-12">
          <div class="bottom-bar-text">
            <p class="text-[11px] font-semibold uppercase tracking-eyebrow text-teal/80">
              Emerge Digital · Dubai Mainland
            </p>
            <p class="bottom-bar-tagline">
              The local prime built for the Vision 2030 decade —
              <span class="text-white">23 years of regional heritage</span>,
              <span class="text-white">a global group of 80,000+</span>,
              <span class="text-white">one accountable contract</span>.
            </p>
          </div>
          <div class="bottom-bar-actions">
            <a href="#what-we-do" class="hero-scroll group inline-flex items-center gap-3 text-[11px] font-semibold uppercase tracking-eyebrow text-platinum/55 transition-colors hover:text-teal">
              <span class="hero-scroll-line h-px w-8 bg-platinum/25 transition-all duration-500 group-hover:w-14 group-hover:bg-teal"></span>
              Scroll the story
              <svg class="h-3 w-3 animate-[float_2.4s_ease-in-out_infinite]" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M6 1v9M2.5 6.5L6 10l3.5-3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ░░ Mobile stack — completely separate clean layout ░░ -->
  <div class="hero-mobile" aria-hidden="false">
    <div class="hero-mobile-bg">
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-hero-premium"></div>
      <div aria-hidden="true" class="aurora-layer-1 absolute inset-0"></div>
      <div aria-hidden="true" class="aurora-layer-2 absolute inset-0"></div>
      <div aria-hidden="true" class="bg-grid bg-grid-fade absolute inset-0 opacity-50"></div>
      <div aria-hidden="true" class="noise absolute inset-0"></div>
    </div>

    <Container class="hero-mobile-content">
      <p class="chip-eyebrow-teal mb-6 mx-auto w-fit">
        <span class="pulse-dot" aria-hidden="true"></span>
        Vision 2030 · {monthsRemaining}mo window
      </p>

      <!-- VISION wordmark — decorative lockup; hidden from the a11y/SEO tree so
           the headline below is the single H1 on this (mobile/reduced-motion) layout -->
      <div class="hero-mobile-vision" aria-hidden="true">VISION</div>
      <p class="hero-mobile-year" aria-hidden="true">2030</p>

      <h1 class="hero-mobile-headline">
        Local Prime.<br/>
        Global Power.<br/>
        <span class="text-gradient-glow">Enterprise Outcomes.</span>
      </h1>

      <p class="hero-mobile-sub">
        The agile Dubai Mainland prime for enterprise CX, Data, AI, and
        digital transformation across MEA.
      </p>

      <div class="hero-mobile-ctas">
        <Button href="/contact/" size="lg" class="btn-shimmer w-full sm:w-auto">
          Book a Readiness Briefing
        </Button>
        <Button variant="ghost" href="/services/" size="lg" class="w-full sm:w-auto">
          Explore the Stack
        </Button>
      </div>

      <div class="hero-mobile-trust">
        <TrustStrip
          prefix="Trusted Across"
          items={['Government', 'BFSI', 'Retail', 'GCC PDPL Aligned']}
        />
      </div>
    </Container>
  </div>
</section>

<style>
  /* ════════════════════════════════════════════════════════════
     OUTER SECTION
     ──────────────────────────────────────────────────────────── */
  .hero-section {
    height: 300vh;            /* 3-screen scroll runway, like Arooth */
    margin-top: -72px;        /* tuck under fixed navbar */
    overflow: clip;
  }
  .hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--color-ink-deep);
  }

  /* ════════════════════════════════════════════════════════════
     LETTERS · V I S I O N
     Three-column grid · 1fr [auto-O] 1fr · O always at viewport center
     ──────────────────────────────────────────────────────────── */
  .letters-wrap {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    z-index: 5;
    pointer-events: none;
    overflow: visible;
  }
  .letters-side {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    overflow: visible;
    font-family: 'Lexend Variable', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(8rem, 22vw, 18rem);
    line-height: 0.85;
    letter-spacing: -0.07em;
    text-transform: uppercase;
    user-select: none;
    filter: drop-shadow(0 0 40px rgba(0, 194, 199, 0.15));
  }
  .letters-left  { justify-content: flex-end;   padding-right: 0.6vw; }
  .letters-right { justify-content: flex-start; padding-left:  0.6vw; }
  .letter {
    display: inline-block;
    flex-shrink: 0;
    padding: 0 0.4vw;
    will-change: transform, opacity;
    /* Gradient applied PER LETTER so background-clip: text actually paints */
    background: linear-gradient(180deg, #FFFFFF 0%, rgba(255,255,255,0.85) 55%, rgba(0,194,199,0.5) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* ════════════════════════════════════════════════════════════
     THE "O" FRAME · expands to reveal hero content
     ──────────────────────────────────────────────────────────── */
  .o-frame {
    position: relative;
    flex-shrink: 0;
    margin: 0 0.6vw;
    width: 38vw;        /* matches Arooth's banner-letter O ratio */
    height: 32vh;
    border-radius: 9999px;
    overflow: visible;  /* ring sits OUTSIDE inner */
    will-change: width, height, border-radius;
    pointer-events: auto;
  }
  .o-inner {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    background: var(--color-ink-deep);
    will-change: border-radius;
  }
  .o-ring {
    position: absolute;
    inset: -3px;
    border: 3px solid rgba(0, 194, 199, 0.85);
    border-radius: inherit;
    pointer-events: none;
    box-shadow:
      0  0 32px  4px rgba(0, 194, 199, 0.45),
      0  0 80px 12px rgba(0, 194, 199, 0.25),
      inset 0 0 30px rgba(0, 194, 199, 0.18);
    will-change: opacity, border-width, box-shadow;
  }

  /* ════════════════════════════════════════════════════════════
     CONTENT INSIDE THE O · always 100vw × 100vh, clipped by O
     ──────────────────────────────────────────────────────────── */
  .o-content {
    position: absolute;
    width: 100vw;
    height: 100vh;
    /* center on the O so headline always sits centered on viewport */
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    overflow: hidden;
    will-change: transform;
  }
  .o-inner-stack {
    position: absolute;
    inset: 0;
    z-index: 5;
    /* Grid 1fr / auto / 1fr · headline anchored at exact viewport center */
    display: grid;
    grid-template-rows: 1fr auto 1fr;
    align-items: stretch;
    justify-items: center;
    text-align: center;
    padding: 0 6vw;
    /* Initial state: pre-scaled to fit the small O on first paint
     * (Motion One scroll() takes over once scroll begins) */
    transform: scale(0.65);
    transform-origin: center center;
    opacity: 0.7;
    will-change: opacity, transform;
  }
  .stack-eyebrow {
    align-self: end;
    margin-bottom: 2rem;
  }
  .stack-h1 {
    align-self: center;
  }
  .stack-extras {
    align-self: start;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 64ch;
  }
  .hero-headline {
    font-family: 'Lexend Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 3.6vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: white;
    text-wrap: balance;
    max-width: 24ch;
    margin: 0;
  }
  .hero-sub {
    font-size: clamp(0.9rem, 1.05vw, 1.125rem);
    line-height: 1.5;
    color: rgba(232, 238, 245, 0.7);
    max-width: 50ch;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* Mini skyline tucked at bottom of content area */
  .dubai-skyline-mini {
    position: absolute;
    inset: auto 0 0 0;
    height: 200px;
    z-index: 1;
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, black 50%);
            mask-image: linear-gradient(180deg, transparent 0%, black 50%);
  }

  /* ════════════════════════════════════════════════════════════
     MARQUEE · bottom of revealed content
     ──────────────────────────────────────────────────────────── */
  .marquee-bar {
    position: absolute;
    inset: auto 0 6vh 0;
    overflow: hidden;
    z-index: 6;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    width: max-content;
    animation: marquee 40s linear infinite;
    font-family: var(--font-family-display, 'Lexend Variable'), sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 3.4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .marquee-chunk { color: rgba(232, 238, 245, 0.55); }
  .marquee-chunk--bold   { font-weight: 800; color: rgba(255,255,255,0.85); }
  .marquee-chunk--italic { font-style: italic; color: rgba(232,238,245,0.55); font-weight: 500; }
  .marquee-chunk--mark   { color: var(--color-teal); font-style: italic; }
  .marquee-chunk--star   { color: var(--color-teal); font-weight: 400; opacity: 0.7; transform: translateY(-0.05em); }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-25%); }   /* 4 copies → 25% loop */
  }

  /* ════════════════════════════════════════════════════════════
     BOTTOM BAR · always-visible details + scroll cue
     Plain div (not Container) so Astro scoped CSS applies cleanly
     ──────────────────────────────────────────────────────────── */
  .bottom-bar-outer {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 30;
    pointer-events: none;
  }
  .bottom-bar {
    display: flex;
    flex-flow: row wrap;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 2.5rem;
    padding-top: 2rem;
    pointer-events: auto;
  }
  .bottom-bar-text { max-width: 32rem; }
  .bottom-bar-tagline {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: rgba(232, 238, 245, 0.5);
  }
  .bottom-bar-actions { display: flex; align-items: center; gap: 1rem; }

  /* ════════════════════════════════════════════════════════════
     AURORA LAYERS (animated)
     ──────────────────────────────────────────────────────────── */
  .aurora-layer-1 {
    background:
      radial-gradient(ellipse 85% 65% at 78% -8%, rgba(0,194,199,0.30), transparent 56%),
      radial-gradient(ellipse 55% 45% at 5% 108%, rgba(61,220,227,0.22), transparent 55%);
    filter: blur(50px);
    animation: aurora-drift 22s ease-in-out infinite;
    will-change: transform;
  }
  .aurora-layer-2 {
    background:
      radial-gradient(ellipse 60% 50% at 85% 60%, rgba(0,194,199,0.14), transparent 60%),
      radial-gradient(ellipse 50% 40% at 15% 40%, rgba(61,220,227,0.10), transparent 55%);
    filter: blur(70px);
    animation: aurora-drift-alt 18s ease-in-out 4s infinite;
    will-change: transform;
  }
  .aurora-layer-3 {
    background:
      radial-gradient(ellipse 40% 35% at 50% 40%, rgba(0,194,199,0.07), transparent 65%);
    filter: blur(90px);
    animation: aurora-drift 28s ease-in-out 8s infinite reverse;
    will-change: transform;
  }
  @keyframes aurora-drift {
    0%, 100% { transform: translate3d(0,0,0) scale(1); opacity: 0.85; }
    50%       { transform: translate3d(2%,-3%,0) scale(1.06); opacity: 1; }
  }
  @keyframes aurora-drift-alt {
    0%, 100% { transform: translate3d(0,0,0) scale(1); opacity: 0.7; }
    33%      { transform: translate3d(-2%,2%,0) scale(1.04); opacity: 0.9; }
    66%      { transform: translate3d(1%,-1%,0) scale(0.97); opacity: 0.75; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(3px); }
  }

  /* ════════════════════════════════════════════════════════════
     STATIC FALLBACK · clean stacked layout
     Used for BOTH:  (a) mobile (≤ 768 px)
                     (b) reduced motion (any width)
     ──────────────────────────────────────────────────────────── */
  .hero-mobile { display: none; }
  .hero-mobile-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: -1;
    background: var(--color-ink-deep);
  }
  .hero-mobile-content {
    padding-top: 7rem;     /* clear navbar */
    padding-bottom: 4rem;
    text-align: center;
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-mobile-vision {
    font-family: 'Lexend Variable', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(4rem, 18vw, 12rem);
    line-height: 0.85;
    letter-spacing: -0.06em;
    background: linear-gradient(180deg, #FFFFFF 0%, rgba(0,194,199,0.5) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    margin: 0;
  }
  .hero-mobile-year {
    font-family: 'Lexend Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.4em;
    color: var(--color-teal);
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .hero-mobile-headline {
    font-family: 'Lexend Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: white;
    margin: 0;
    text-wrap: balance;
  }
  .hero-mobile-sub {
    margin-top: 1.5rem;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(232, 238, 245, 0.7);
    max-width: 38rem;
    margin-left: auto;
    margin-right: auto;
