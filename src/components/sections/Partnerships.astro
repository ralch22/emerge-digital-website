---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Card from '../Card.astro';
import Button from '../Button.astro';

const partners = [
  {
    name: 'e-CENS (Nuummite Consulting)',
    points: [
      '23 years of operating heritage in the Middle East',
      '7 offices across the MEA region',
      'One of only four Global Google Marketing Platform Partners worldwide',
      'Deep specializations in Digital Analytics, CX, MarTech, and Commerce',
    ],
  },
  {
    name: 'FPT Corporation',
    points: [
      'US$2B+ annual revenue',
      '80,000+ engineers globally',
      'Operations across 30+ countries',
      'Enterprise modernization, cloud, AI engineering, managed services',
    ],
  },
];
---

<Section tone="dark">
  <Container>
    <div class="max-w-3xl">
      <Eyebrow>Strategic Partnerships</Eyebrow>
      <h2 class="mt-4 text-display-lg">
        Built on two of the strongest names in regional and global delivery.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      {
        partners.map((p) => (
          <Card tone="dark" class="flex h-full flex-col">
            <h3 class="text-display-md">{p.name}</h3>
            <ul class="mt-6 space-y-3">
              {p.points.map((point) => (
                <li class="flex gap-3 text-platinum/85">
                  <span aria-hidden="true" class="mt-1 inline-block h-1.5 w-1.5 flex-none rounded-full bg-teal" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </Card>
        ))
      }
    </div>

    <div class="mt-12">
      <Button variant="ghost" href="/partnerships/">Read about each partner</Button>
    </div>
  </Container>
</Section>
