---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';

// The three named ecosystem properties, each with its own funnel link.
// URLs and copy per docs/ecosystem-north-star.md — do NOT claim "runs on VaultOS", no pricing.
const utm = '?utm_source=vision&utm_medium=cta&utm_campaign=ecosystem';

const tiles = [
  {
    title: 'Agentforce practice',
    badge: 'Practice',
    body: 'Human-led, governed Agentforce delivery for Gulf Government and BFSI — Agentforce that earns its keep.',
    href: `https://future.emergedigital.com${utm}`,
  },
  {
    title: 'Vela OS',
    badge: 'Live',
    body: 'The live ROAI command center — governance cadence, named KPIs, and run-state operations in one view.',
    href: `https://roai.emergedigital.ae${utm}`,
  },
  {
    title: 'VaultOS',
    badge: 'Product',
    body: 'Knowledge your agents can run on — OKF-compliant, governed, agent-ready.',
    proof: 'Emerge runs its own operations on it: 327+ documents across 6 businesses.',
    href: `https://vault.emergedigital.com${utm}`,
  },
];
---

<Section tone="dark" id="ecosystem" class="relative overflow-hidden">
  <!-- Ambient glow, matched to the surrounding command-center language -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div
      class="absolute left-1/2 top-0 h-[360px] w-[760px] -translate-x-1/2"
      style="background: radial-gradient(ellipse, rgba(0,194,199,0.06) 0%, transparent 70%); filter: blur(70px);"
    >
    </div>
  </div>

  <Container class="relative">
    <div class="max-w-3xl">
      <Eyebrow data-reveal>The Ecosystem</Eyebrow>
      <h2 class="mt-4 text-display-lg" data-reveal data-reveal-delay="1">
        Practice, live proof,
        <span class="text-gradient-accent">and the knowledge layer.</span>
      </h2>
      <p class="mt-6 max-w-prose text-lead text-platinum/75" data-reveal data-reveal-delay="2">
        Three connected properties behind our AI delivery — the Agentforce practice, the live ROAI
        platform, and the governed knowledge layer that keeps enterprise AI accountable.
      </p>
    </div>

    <ul class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        tiles.map((tile, i) => (
          <li data-reveal data-reveal-delay={String(i + 1)}>
            <a
              href={tile.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex h-full flex-col rounded-card border border-white/8 p-7 transition-all duration-400 hover:-translate-y-1 hover:border-teal/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
              style="background: rgba(255,255,255,0.025); backdrop-filter: blur(12px);"
            >
              {/* Top border accent */}
              <div class="absolute inset-x-0 top-0 h-[1.5px] origin-left scale-x-0 rounded-t-card bg-gradient-accent transition-transform duration-500 ease-out-quint group-hover:scale-x-100" />

              <div class="flex items-start justify-between gap-3">
                <h3 class="text-display-sm text-white transition-colors duration-300 group-hover:text-teal">
                  {tile.title}
                </h3>
                <span class="shrink-0 rounded-pill border border-teal/25 bg-teal/[0.08] px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-teal">
                  {tile.badge}
                </span>
              </div>

              <p class="mt-3 text-sm leading-relaxed text-platinum/65 transition-colors duration-300 group-hover:text-platinum/85">
                {tile.body}
              </p>

              {tile.proof && (
                <p class="mt-4 border-t border-white/8 pt-4 font-mono text-[11px] leading-relaxed text-platinum/55">
                  {tile.proof}
                </p>
              )}

              <span class="mt-auto inline-flex items-center gap-1.5 pt-6 font-label text-xs uppercase tracking-wide text-teal/80 transition-colors duration-300 group-hover:text-teal">
                Visit
                <svg
                  width="11"
                  height="11"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="transition-transform duration-300 group-hover:translate-x-0.5"
                >
                  <path d="M7 13L13 7M8 7h5v5" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Section>
