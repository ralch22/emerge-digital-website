---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const pillars = [
  {
    title: 'Customer Experience',
    note:  'CX Division — led by Rami, Founder',
    href:  '/services/#cx',
    items: [
      'CX Strategy & Design',
      'MarTech & Customer Data Orchestration (CDP)',
      'Commerce & Platform Development',
    ],
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="7" r="3.5"/>
      <path d="M2 20c0-4 3-6 7-6"/>
      <path d="M16 14l2 2 4-4"/>
    </svg>`,
    accentColor: 'rgba(0,194,199,1)',
  },
  {
    title: 'Data & Analytics',
    note:  '23 years of regional analytics heritage',
    href:  '/services/#data',
    items: [
      'Digital Analytics & Data Science',
      'Data & Tag Governance',
      'Media & AdTech Excellence',
    ],
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 17l4-5 4 3 4-7 4 3"/>
      <rect x="3" y="3" width="16" height="16" rx="2"/>
    </svg>`,
    accentColor: 'rgba(61,220,227,1)',
  },
  {
    title: 'AI & Generative Solutions',
    note:  'Outcomes, delivered by senior teams + governed AI',
    href:  '/services/#ai',
    items: [
      'Enterprise GenAI deployments',
      'AI for personalisation & CX',
      'AI governance & trust frameworks',
    ],
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="3"/>
      <path d="M11 4V2M11 20v-2M4 11H2M20 11h-2"/>
      <path d="M6.3 6.3 4.9 4.9M17.1 6.3l1.4-1.4M6.3 15.7l-1.4 1.4M17.1 15.7l1.4 1.4"/>
      <circle cx="11" cy="11" r="7" stroke-dasharray="3 3"/>
    </svg>`,
    accentColor: 'rgba(0,245,255,1)',
  },
  {
    title: 'Digital Transformation',
    note:  'Backed by a global technology group of 80,000+',
    href:  '/services/#transformation',
    items: [
      'Enterprise application modernisation',
      'Cloud & platform engineering',
      'Managed services & run-state operations',
    ],
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7" rx="1.5"/>
      <rect x="12" y="3" width="7" height="7" rx="1.5"/>
      <rect x="3" y="12" width="7" height="7" rx="1.5"/>
      <path d="M17 12v2a2 2 0 0 1-2 2h-2"/>
      <path d="M19 12l-2-2-2 2"/>
    </svg>`,
    accentColor: 'rgba(0,194,199,1)',
  },
];
---

<Section tone="light" id="what-we-do">
  <Container>
    <!-- Header -->
    <div class="max-w-3xl">
      <Eyebrow tone="cool" data-reveal>What We Do</Eyebrow>
      <h2 class="mt-4 text-display-lg text-slate" data-reveal data-reveal-delay="1">
        A full-stack capability bench for
        <span class="text-teal">CX, Data, AI,</span> and Transformation.
      </h2>
      <p class="mt-6 text-lead text-slate/75" data-reveal data-reveal-delay="2">
        Emerge Digital is led personally by our founder Rami, who heads the CX Division.
        The full capability stack extends across Data, AI, and Enterprise Modernisation,
        giving you a single contracting partner for programs that would otherwise require
        three or four separate vendors.
      </p>
    </div>

    <!-- Service cards -->
    <div class="mt-14 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
      {pillars.map((p, i) => (
        <article
          class="service-card-premium group flex h-full flex-col rounded-card border border-slate/10 bg-white p-7 shadow-sm"
          data-reveal
          data-reveal-delay={String(i + 1)}
          style={`--mx: 50%; --my: 50%;`}
        >
          <!-- Icon + note row -->
          <div class="flex items-start justify-between gap-3">
            <div
              class="icon-wrap"
              style={`color: ${p.accentColor}`}
              set:html={p.icon}
            ></div>
            <span class="rounded-pill border border-teal/15 bg-teal/[0.06] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-teal">
              {p.note.split('—')[0].trim()}
            </span>
          </div>

          <!-- Title -->
          <h3 class="mt-5 text-display-md text-slate transition-colors duration-300 group-hover:text-teal">
            {p.title}
          </h3>

          <!-- Services list -->
          <ul class="mt-4 flex-1 space-y-2">
            {p.items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm leading-snug text-slate/70">
                <span
                  aria-hidden="true"
                  class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-teal/60 transition-transform duration-300 group-hover:scale-125 group-hover:bg-teal"
                ></span>
                {item}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div class="mt-6 border-t border-slate/8 pt-5">
            <a
              href={p.href}
              class="group/link inline-flex items-center gap-1.5 text-sm font-semibold text-teal transition-all duration-300 hover:gap-3"
            >
              Explore
              <span aria-hidden="true" class="transition-transform duration-300 group-hover/link:translate-x-1">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12">
      <Button variant="secondary" surface="light" href="/services/" size="lg" data-reveal>
        Explore all capabilities
      </Button>
    </div>
  </Container>
</Section>

<script>
  // Wire up mouse-tracked spotlight on service cards (light surface)
  document.querySelectorAll<HTMLElement>('.service-card-premium').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${((e.clientX - rect.left) / rect.width) * 100}%`);
      card.style.setProperty('--my', `${((e.clientY - rect.top)  / rect.height) * 100}%`);
    });
  });
</script>
