---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const pillars = [
  {
    eyebrow: 'The Local Prime',
    title: 'In-country accountability',
    tagline: 'Dubai Mainland · Commercial owner · Single contract',
    body:
      'Emerge Digital is the independently registered Dubai Mainland entity that owns the client relationship, structures the engagement, signs the contract, and carries full commercial and compliance responsibility. One throat to choke. One MEA-licensed counterparty. Zero ambiguity for procurement.',
    accent: true,
  },
  {
    eyebrow: 'The Regional Heritage',
    title: '23 years of MEA delivery',
    tagline: '7 offices · CX, data, analytics, MarTech leadership',
    body:
      'A deep, GCC-native delivery bench built across two decades. Recognized leadership in digital analytics, customer experience, and growth — including standing as one of only four Global Google Marketing Platform Partners worldwide. Already operating across Dubai, Riyadh, Cairo, and beyond.',
    accent: false,
  },
  {
    eyebrow: 'The Global Engine',
    title: '80,000+ engineers behind every program',
    tagline: 'Worldwide network · Modernization · Cloud · AI · Run',
    body:
      'A global engineering footprint spanning Asia, Europe, and the Americas plugs in behind every engagement — bringing enterprise-grade application modernization, cloud, AI engineering, and managed services capacity to MEA programs at the scale only a true global SI can offer.',
    accent: false,
  },
];
---

<Section tone="dark" id="why-emerge">
  <Container>
    <div class="max-w-3xl">
      <Eyebrow data-reveal>The Operating Model</Eyebrow>
      <h2 class="mt-4 text-display-lg" data-reveal data-reveal-delay="1">
        One commercial engine. Three sources of unfair advantage.
      </h2>
      <p class="mt-6 max-w-prose text-lead text-platinum/80" data-reveal data-reveal-delay="2">
        We combine the speed of a local prime, the depth of a 23-year regional bench,
        and the muscle of a global engineering network — under a single Dubai Mainland
        contract.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        pillars.map((p, i) => (
          <article
            class:list={[
              'pillar-card group relative overflow-hidden rounded-card border border-white/10 bg-navy/40 p-8 transition duration-300 hover:-translate-y-1 hover:border-teal/40 hover:bg-navy/60',
              p.accent && 'pillar-accent',
            ]}
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <div aria-hidden="true" class="pillar-glow pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100" />
            <p class="text-eyebrow uppercase font-semibold text-teal">{p.eyebrow}</p>
            <h3 class="mt-3 text-display-md text-white">{p.title}</h3>
            <p class="mt-3 font-mono text-xs uppercase tracking-wider text-cyan/90">{p.tagline}</p>
            <p class="mt-5 text-platinum/85">{p.body}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-12">
      <Button variant="ghost" href="/about/">Read the full story</Button>
    </div>
  </Container>
</Section>

<style>
  .pillar-accent {
    border-color: rgba(0, 194, 199, 0.45);
    box-shadow:
      0 0 0 1px rgba(0, 194, 199, 0.18),
      0 20px 60px -20px rgba(0, 194, 199, 0.25);
  }

  .pillar-glow {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0, 194, 199, 0.18), transparent 70%);
  }
</style>
