---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const reasons = [
  {
    title: 'One Mainland counterparty.',
    body:
      'A single Dubai Mainland legal entity owns your contract, your invoices, and your compliance obligations across the GCC. No offshore proxies, no ambiguity for procurement or legal.',
  },
  {
    title: 'Founder-level account ownership.',
    body:
      'Every engagement is structured and led at founder level. You get senior judgment from day one — not the second-tier account staffing typical of large global SIs.',
  },
  {
    title: 'Crawl-Walk-Run engagement model.',
    body:
      'We start with a focused, low-risk diagnostic ("Crawl"), expand to a defined transformation phase ("Walk"), and scale into a long-term program ("Run") — each phase with clear gates and outcomes.',
  },
  {
    title: 'Vision 2030 procurement readiness.',
    body:
      'We are pre-aligned to GCC procurement, ESR/UBO, and in-country compliance frameworks. Programs that take 9 months to mobilize with offshore vendors mobilize with us in 6 weeks.',
  },
  {
    title: 'Global muscle behind every program.',
    body:
      'Tap into a 23-year MEA delivery heritage and an 80,000-engineer global bench — at local-prime accountability and pricing.',
  },
];
---

<Section tone="dark">
  <Container>
    <div class="max-w-3xl">
      <Eyebrow data-reveal>Why Emerge</Eyebrow>
      <h2 class="mt-4 text-display-lg" data-reveal data-reveal-delay="1">Five reasons enterprise buyers choose a local prime.</h2>
    </div>

    <ol class="mt-14 grid gap-px overflow-hidden rounded-card border border-white/10 bg-white/5 lg:grid-cols-2">
      {
        reasons.map((r, i) => (
          <li class="reason-cell group relative bg-ink p-8 transition duration-300 hover:bg-navy/60 lg:p-10" data-reveal data-reveal-delay={String((i % 2) + 1)}>
            <div aria-hidden="true" class="reason-marker absolute left-0 top-0 h-full w-[3px] origin-top scale-y-0 bg-gradient-to-b from-teal to-cyan transition-transform duration-500 group-hover:scale-y-100" />
            <p class="font-mono text-display-md text-teal">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="mt-3 text-display-md">{r.title}</h3>
            <p class="mt-3 text-platinum/80">{r.body}</p>
          </li>
        ))
      }
      <li class="flex flex-col justify-center bg-ink p-8 lg:p-10">
        <p class="text-platinum/85">
          The local-prime model is how we turn "global SI scale" into "in-country
          accountability" — without losing either side of the equation.
        </p>
        <div class="mt-5">
          <Button variant="ghost" href="/about/">See how the local-prime model works</Button>
        </div>
      </li>
    </ol>
  </Container>
</Section>
