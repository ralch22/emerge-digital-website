---
import { getCollection } from 'astro:content';
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

const studies = (await getCollection('case-studies', ({ data }) => data.published))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<Section tone="light">
  <Container>
    <div class="max-w-3xl">
      <Eyebrow tone="cool" data-reveal>Proof</Eyebrow>
      <h2 class="mt-4 text-display-lg text-slate" data-reveal data-reveal-delay="1">
        What enterprise outcomes look like in practice.
      </h2>
      <p class="mt-6 text-lead text-slate/80" data-reveal data-reveal-delay="2">
        A selection of programs we've led for Government, BFSI, and Retail leaders across
        the MEA region.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {studies.map((study, i) => (
        <a
          href={`/case-studies/${study.slug}/`}
          class="group flex h-full flex-col rounded-card border border-platinum bg-white p-8 no-underline shadow-sm transition duration-300 hover:-translate-y-1 hover:border-teal/40 hover:shadow-elevated"
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            <span class="rounded-pill border border-teal/20 bg-teal/8 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-teal">
              {study.data.industry}
            </span>
            <span class="rounded-pill border border-slate/10 bg-slate/5 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-slate/50">
              {study.data.region}
            </span>
          </div>

          <!-- Client name -->
          {study.data.client && (
            <p class="mt-4 text-eyebrow uppercase text-slate/50">{study.data.client}</p>
          )}

          <!-- Title -->
          <h3 class="mt-2 text-display-md text-slate transition group-hover:text-teal">
            {study.data.title}
          </h3>

          <!-- Outcome callout -->
          <div class="mt-5 flex items-start gap-2.5 rounded-xl border border-teal/15 bg-teal/[0.06] p-4">
            <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-teal" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1.5 8.5 L4.5 5.5 L7.5 8 L12.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p class="text-xs font-semibold leading-snug text-teal">{study.data.outcome}</p>
          </div>

          <!-- Capabilities -->
          <div class="mt-5 flex flex-1 flex-wrap gap-1.5">
            {study.data.capabilities.slice(0, 2).map((cap) => (
              <span class="rounded border border-slate/10 bg-slate/5 px-2 py-0.5 text-[10px] uppercase tracking-wide text-slate/50">
                {cap}
              </span>
            ))}
          </div>

          <!-- Read more -->
          <div class="mt-6 flex items-center gap-1.5 text-sm font-semibold text-teal transition group-hover:gap-3">
            Read the full story <span aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <Button variant="secondary" surface="light" href="/case-studies/" size="lg">
        See all case studies
      </Button>
    </div>
  </Container>
</Section>
