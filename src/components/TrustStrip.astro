---
import Eyebrow from './Eyebrow.astro';

interface Props {
  prefix?: string;
  items: string[];
  class?: string;
}

const { prefix, items, class: className = '' } = Astro.props;
---

<div class:list={['flex flex-col items-start gap-3', className]}>
  {prefix && <Eyebrow tone="cool">{prefix}</Eyebrow>}
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
    {
      items.map((item, i) => (
        <>
          <span class="font-medium text-white/90">{item}</span>
          {i < items.length - 1 && (
            <span aria-hidden="true" class="text-cool">·</span>
          )}
        </>
      ))
    }
  </div>
</div>
