---
/**
 * Navbar — sticky, scroll-aware site header.
 *  - Compresses on scroll (padding + glass blur)
 *  - Teal gradient scroll-progress bar
 *  - Active page detection
 *  - Mobile sheet with focus trap
 */

const navItems = [
  { href: '/services/',     label: 'Services' },
  { href: '/case-studies/', label: 'Case Studies' },
  { href: '/insights/',     label: 'Insights' },
  { href: '/about/',        label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  data-site-header
  class="fixed inset-x-0 top-0 z-50 transition-[padding,background-color,backdrop-filter] duration-500 ease-out-quint"
>
  <div
    class="header-surface relative mx-auto flex max-w-wide items-center justify-between gap-6 px-6 py-4 transition-all duration-500 ease-out-quint sm:px-8 lg:px-12"
  >
    <!-- Logo -->
    <a
      href="/"
      class="group relative z-10 flex items-center gap-2.5 font-display text-[15px] font-semibold tracking-tight text-white"
      aria-label="Emerge Digital — home"
    >
      <span class="logo-mark relative inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-accent text-ink transition-all duration-300 group-hover:shadow-glow">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 4h12M3 9h8M3 14h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="hidden sm:inline-flex items-baseline gap-px">
        Emerge<span class="text-teal transition-colors duration-300 group-hover:text-cyan">.</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden lg:flex">
      <ul class="flex items-center gap-1 text-[13px] font-medium text-platinum/75">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'nav-link relative inline-flex px-3.5 py-2 transition-colors duration-300 hover:text-white rounded-lg hover:bg-white/5 active:bg-white/10',
                  isActive ? 'text-white' : 'text-platinum/70',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2.5">
      <a
        href="/contact/"
        class="hidden md:inline-flex group items-center gap-1.5 rounded-pill bg-gradient-accent px-5 py-2.5 text-[13px] font-semibold text-ink transition-all duration-300 hover:shadow-glow hover:scale-[1.03] active:scale-100"
      >
        Book a Briefing
        <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
      </a>

      <button
        id="nav-toggle"
        type="button"
        aria-label="Open navigation"
        aria-controls="mobile-nav"
        aria-expanded="false"
        class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-white transition-all hover:bg-white/10 hover:border-white/20"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path class="hamburger-top"    d="M2 5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path class="hamburger-mid"    d="M2 9h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path class="hamburger-bottom" d="M2 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Scroll progress bar -->
  <div aria-hidden="true" class="scroll-progress" data-scroll-progress></div>
</header>

<!-- Spacer under fixed header -->
<div aria-hidden="true" class="h-[72px]"></div>

<!-- Mobile sheet -->
<div id="mobile-nav" aria-hidden="true" class="mobile-sheet fixed inset-0 z-[60] hidden">
  <div class="mobile-sheet-backdrop absolute inset-0 bg-ink/85 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  <aside
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
    class="mobile-sheet-panel absolute right-0 top-0 h-full w-[88%] max-w-sm translate-x-full bg-gradient-ink border-l border-white/8 shadow-2xl transition-transform duration-500 ease-out-quint"
  >
    <!-- Sheet header -->
    <div class="flex items-center justify-between border-b border-white/8 px-6 py-4">
      <a href="/" class="flex items-center gap-2 font-display text-[15px] font-semibold text-white">
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-accent text-ink">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3 4h12M3 9h8M3 14h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        Emerge<span class="text-teal">.</span>
      </a>
      <button
        id="nav-close"
        type="button"
        aria-label="Close navigation"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-white transition-colors hover:bg-white/10"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 3l10 10M13 3 3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav aria-label="Mobile primary" class="px-4 py-5">
      <ul class="space-y-0.5">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'mobile-link group flex items-center justify-between rounded-xl px-4 py-3 text-base font-medium transition-all hover:bg-white/6 hover:text-white active:bg-white/10',
                  isActive ? 'bg-teal/8 text-white border border-teal/15' : 'text-platinum/80 border border-transparent',
                ]}
              >
                <span>{item.label}</span>
                <span
                  aria-hidden="true"
                  class:list={[
                    'text-sm transition-transform duration-300 group-hover:translate-x-1',
                    isActive ? 'text-teal' : 'text-cool group-hover:text-teal',
                  ]}
                >→</span>
              </a>
            </li>
          );
        })}
      </ul>
      <a
        href="/contact/"
        class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-pill bg-gradient-accent px-5 py-3 text-sm font-semibold text-ink transition-all hover:shadow-glow"
      >
        Book a Briefing <span aria-hidden="true">→</span>
      </a>
    </nav>

    <!-- Sheet footer -->
    <div class="absolute bottom-0 left-0 right-0 border-t border-white/8 px-6 py-4">
      <p class="text-[11px] text-cool">Emerge Digital FZ-LLC · Dubai Mainland</p>
    </div>
  </aside>
</div>

<style>
  .header-surface {
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.5s var(--ease-out-quint),
      border-color     0.5s var(--ease-out-quint),
      backdrop-filter  0.5s var(--ease-out-quint),
      padding          0.5s var(--ease-out-quint);
  }
  [data-site-header][data-scrolled='true'] .header-surface {
    background-color: rgba(6, 18, 42, 0.78);
    border-bottom-color: rgba(255, 255, 255, 0.06);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  /* Logo mark */
  .logo-mark {
    box-shadow: 0 0 0 1px rgba(0,194,199,0.35), 0 4px 14px rgba(0,194,199,0.2);
    transition: box-shadow 0.3s var(--ease-out-quint);
  }

  /* Animated nav underline */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 5px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-teal), var(--color-cyan));
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s var(--ease-out-quint);
  }
  .nav-link:hover::after,
  .nav-link[aria-current='page']::after { transform: scaleX(1); }

  /* Scroll progress */
  .scroll-progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1.5px;
    width: 100%;
    background: linear-gradient(90deg, var(--color-teal), var(--color-cyan), var(--color-teal-glow));
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
  }
  [data-site-header][data-scrolled='true'] .scroll-progress { opacity: 0.9; }

  /* Mobile sheet states */
  .mobile-sheet[data-open='true'] { display: block; }
  .mobile-sheet[data-open='true'] .mobile-sheet-backdrop { opacity: 1; }
  .mobile-sheet[data-open='true'] .mobile-sheet-panel { transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .header-surface, .scroll-progress,
    .mobile-sheet-backdrop, .mobile-sheet-panel,
    .nav-link::after { transition: none !important; }
  }
</style>

<script>
  // Scroll-aware header + progress bar
  const header   = document.querySelector<HTMLElement>('[data-site-header]');
  const progress = document.querySelector<HTMLElement>('[data-scroll-progress]');

  if (header && progress) {
    let ticking = false;
    const update = () => {
      const y   = window.scrollY;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      header.dataset.scrolled = y > 8 ? 'true' : 'false';
      progress.style.transform = `scaleX(${max > 0 ? Math.min(1, y / max) : 0})`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
    update();
  }

  // Mobile sheet
  const toggle = document.getElementById('nav-toggle');
  const close  = document.getElementById('nav-close');
  const sheet  = document.getElementById('mobile-nav');

  const openSheet = () => {
    if (!sheet || !toggle) return;
    sheet.dataset.open = 'true';
    sheet.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.documentElement.classList.add('lenis-stopped');
    requestAnimationFrame(() => sheet.querySelector<HTMLElement>('a, button')?.focus());
  };
  const closeSheet = () => {
    if (!sheet || !toggle) return;
    sheet.dataset.open = 'false';
    sheet.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.documentElement.classList.remove('lenis-stopped');
    setTimeout(() => { if (sheet.dataset.open !== 'true') sheet.style.display = ''; }, 500);
    toggle.focus();
  };

  toggle?.addEventListener('click', openSheet);
  close?.addEventListener('click', closeSheet);
  sheet?.querySelector('.mobile-sheet-backdrop')?.addEventListener('click', closeSheet);
  sheet?.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => a.addEventListener('click', closeSheet));
  document.addEventListener('keydown', (e) => {
    if (!sheet || sheet.dataset.open !== 'true') return;

    if (e.key === 'Escape') { closeSheet(); return; }

    // Focus trap — keep Tab focus within the open sheet (dialog is aria-modal)
    if (e.key === 'Tab') {
      const focusables = sheet.querySelectorAll<HTMLElement>('a[href], button:not([disabled])');
      if (!focusables.length) return;
      const first = focusables[0];
      const last  = focusables[focusables.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
