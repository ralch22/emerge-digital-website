---
/**
 * Footer — premium 4-column layout with marquee word and compliance line.
 */

const year = new Date().getFullYear();

const company = [
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Capabilities' },
  { href: '/contact/', label: 'Contact' },
];
const capabilities = [
  { href: '/case-studies/', label: 'Case Studies' },
  { href: '/insights/', label: 'Insights' },
  { href: '/services/#cx', label: 'CX Division' },
  { href: '/services/#data', label: 'Data & Analytics' },
];
const legal = [
  { href: '/legal/privacy/', label: 'Privacy' },
  { href: '/legal/cookies/', label: 'Cookies' },
  { href: '/legal/terms/', label: 'Terms' },
];
---

<footer class="footer-surface relative isolate overflow-hidden border-t border-white/5">
  <div aria-hidden="true" class="footer-glow pointer-events-none absolute inset-0"></div>
  <div aria-hidden="true" class="footer-grid pointer-events-none absolute inset-0"></div>

  <!-- Big oversized wordmark -->
  <div aria-hidden="true" class="relative pt-20 sm:pt-24">
    <div class="mx-auto max-w-wide px-6 sm:px-8 lg:px-12">
      <div class="font-display text-[18vw] sm:text-[14vw] leading-[0.9] font-semibold tracking-tightest text-white/[0.04] select-none">
        Emerge.
      </div>
    </div>
  </div>

  <div class="relative mx-auto max-w-wide px-6 pb-12 pt-10 text-sm text-cool sm:px-8 lg:px-12">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href="/" class="font-display text-lg font-semibold tracking-tight text-white">
          Emerge<span class="text-teal">.</span>
        </a>
        <p class="mt-4 max-w-xs text-platinum/70">
          The Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation across the MEA region.
        </p>
        <a
          href="/contact/"
          class="mt-6 inline-flex items-center gap-2 rounded-pill border border-teal/40 bg-teal/10 px-4 py-2 text-[13px] font-semibold text-white transition hover:bg-teal/20 hover:border-teal/60"
        >
          Book a Vision 2030 Briefing
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-[12px] font-semibold uppercase tracking-eyebrow text-white/90">Company</h4>
        <ul class="mt-4 space-y-2.5">
          {company.map((item) => (
            <li><a href={item.href} class="footer-link">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-[12px] font-semibold uppercase tracking-eyebrow text-white/90">Capabilities</h4>
        <ul class="mt-4 space-y-2.5">
          {capabilities.map((item) => (
            <li><a href={item.href} class="footer-link">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-[12px] font-semibold uppercase tracking-eyebrow text-white/90">Compliance</h4>
        <p class="mt-4 leading-relaxed text-platinum/70">
          Emerge Digital FZ-LLC<br />
          Dubai, United Arab Emirates<br />
          ESR &amp; UBO Compliant · GCC PDPL Aligned
        </p>
      </div>
    </div>

    <div class="mt-14 hairline"></div>

    <div class="mt-6 flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
      <p class="text-[12px] text-cool">© {year} Emerge Digital. All rights reserved.</p>
      <ul class="flex gap-6 text-[12px]">
        {legal.map((item) => (
          <li><a href={item.href} class="footer-link">{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <style>
    .footer-surface {
      background: linear-gradient(180deg, #06122A 0%, #03081A 100%);
    }
    .footer-glow {
      background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0, 194, 199, 0.08), transparent 70%);
    }
    .footer-grid {
      background-image:
        linear-gradient(to right, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: linear-gradient(180deg, transparent, black 30%, black 60%, transparent);
      -webkit-mask-image: linear-gradient(180deg, transparent, black 30%, black 60%, transparent);
    }
    .footer-link {
      @apply inline-flex items-center text-platinum/65 transition-colors duration-300 hover:text-white;
    }
    .footer-link:hover {
      color: var(--color-cyan);
    }
  </style>
</footer>
