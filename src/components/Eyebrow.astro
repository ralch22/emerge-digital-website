---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'p'> {
  tone?: 'teal' | 'cool' | 'white';
  as?: 'p' | 'span' | 'div';
}

const { tone = 'teal', as = 'p', class: className = '', ...rest } = Astro.props;

const tones = {
  teal: 'text-teal',
  cool: 'text-cool',
  white: 'text-white/80',
} as const;

const Tag = as;
---

<Tag class:list={['text-eyebrow uppercase font-semibold', tones[tone], className]} {...rest}>
  <slot />
</Tag>
