---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';

const reasons = [
  { label: 'Scoping a Crawl-phase diagnostic' },
  { label: 'Mid-RFP and need a local-prime counterparty' },
  { label: 'Evaluating CDP or MarTech platforms' },
  { label: 'Building a Vision 2030 business case' },
  { label: 'Looking for a managed-services partner' },
  { label: 'Something else' },
];
---

<BaseLayout
  title="Contact Emerge Digital — Book a Vision 2030 Readiness Briefing"
  description="Book a 30-minute Readiness Briefing with Rami, Founder of Emerge Digital. We'll map your priorities to the 2026–2027 procurement window and show how the local-prime model works."
>
  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-hero pb-0 pt-section-sm md:pt-24">
    <div class="pointer-events-none absolute inset-0 bg-grid bg-grid-fade" aria-hidden="true"></div>
    <div class="aurora pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
    <Container>
      <div class="max-w-2xl pb-16">
        <div class="chip-eyebrow mb-6">
          <span class="pulse-dot" aria-hidden="true"></span>
          Book a Briefing
        </div>
        <h1 class="text-display-xl text-white">
          Let's talk<br />
          <span class="text-gradient-accent">Vision 2030.</span>
        </h1>
        <p class="mt-6 text-lead text-platinum/75">
          Whether you're scoping a Crawl-phase diagnostic or already mid-RFP, the fastest path
          forward is a 30-minute conversation with our founder.
        </p>
      </div>
    </Container>
    <div class="hairline" aria-hidden="true"></div>
  </section>

  <!-- ── Two-column layout ─────────────────────────────── -->
  <section class="bg-ink py-section-sm md:py-section">
    <Container>
      <div class="grid gap-16 lg:grid-cols-[1fr_380px]">

        <!-- ── Form ──────────────────────────────────────── -->
        <div>
          <Eyebrow class="mb-6">Request a briefing</Eyebrow>

          <!-- Success state (hidden until JS shows it) -->
          <div
            id="form-success"
            class="hidden rounded-2xl border border-teal/30 bg-teal/5 p-10 text-center"
            role="status"
            aria-live="polite"
          >
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal/15">
              <svg class="h-6 w-6 text-teal" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h2 class="text-display-md text-white">Request received.</h2>
            <p class="mt-3 text-platinum/70">
              Thank you — we'll be in touch within one business day to confirm your briefing slot.
            </p>
          </div>

          <form
            id="contact-form"
            name="briefing-request"
            method="POST"
            data-form
            data-endpoint="/api/contact"
            class="space-y-6"
            novalidate
          >
            <!-- Hidden fields for form identification -->
            <input type="hidden" name="form-name" value="briefing-request" />
            <input type="hidden" name="form-source" value="contact-page" />

            <!-- Name + Company row -->
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="field-group">
                <label for="full-name" class="field-label">Full name <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="full-name"
                  name="full-name"
                  autocomplete="name"
                  required
                  class="field-input"
                  placeholder="Yousef Al-Rashidi"
                />
                <p class="field-error hidden" role="alert"></p>
              </div>
              <div class="field-group">
                <label for="company" class="field-label">Company <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  autocomplete="organization"
                  required
                  class="field-input"
                  placeholder="ACME Holdings"
                />
                <p class="field-error hidden" role="alert"></p>
              </div>
            </div>

            <!-- Work email + Role row -->
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="field-group">
                <label for="email" class="field-label">Work email <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  class="field-input"
                  placeholder="you@company.com"
                />
                <p class="field-error hidden" role="alert"></p>
              </div>
              <div class="field-group">
                <label for="role" class="field-label">Role / Title <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="role"
                  name="role"
                  autocomplete="organization-title"
                  required
                  class="field-input"
                  placeholder="Chief Customer Officer"
                />
                <p class="field-error hidden" role="alert"></p>
              </div>
            </div>

            <!-- Country + Industry row -->
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="field-group">
                <label for="country" class="field-label">Country <span class="text-teal" aria-hidden="true">*</span></label>
                <select id="country" name="country" required class="field-input field-select">
                  <option value="" disabled selected>Select country</option>
                  <option value="UAE">UAE</option>
                  <option value="KSA">Saudi Arabia (KSA)</option>
                  <option value="Egypt">Egypt</option>
                  <option value="Kuwait">Kuwait</option>
                  <option value="Bahrain">Bahrain</option>
                  <option value="Oman">Oman</option>
                  <option value="Qatar">Qatar</option>
                  <option value="Other">Other</option>
                </select>
                <p class="field-error hidden" role="alert"></p>
              </div>
              <div class="field-group">
                <label for="industry" class="field-label">Industry <span class="text-teal" aria-hidden="true">*</span></label>
                <select id="industry" name="industry" required class="field-input field-select">
                  <option value="" disabled selected>Select industry</option>
                  <option value="Government">Government / Public Sector</option>
                  <option value="BFSI">Banking & Financial Services</option>
                  <option value="Retail">Retail & Consumer</option>
                  <option value="Telco">Telco</option>
                  <option value="Healthcare">Healthcare</option>
                  <option value="Energy">Energy & Utilities</option>
                  <option value="Other">Other</option>
                </select>
                <p class="field-error hidden" role="alert"></p>
              </div>
            </div>

            <!-- Reason for reaching out -->
            <fieldset>
              <legend class="field-label mb-3">What best describes your situation?</legend>
              <div class="flex flex-wrap gap-2">
                {reasons.map((r) => (
                  <label class="reason-chip cursor-pointer">
                    <input
                      type="checkbox"
                      name="reason"
                      value={r.label}
                      class="sr-only"
                    />
                    <span class="inline-flex select-none items-center rounded-pill border border-white/10 bg-white/5 px-3.5 py-1.5 text-sm text-platinum/70 transition-colors duration-200 hover:border-teal/40 hover:text-teal">
                      {r.label}
                    </span>
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Brief -->
            <div class="field-group">
              <label for="brief" class="field-label">What's the brief? <span class="text-cool text-xs font-normal">(optional)</span></label>
              <textarea
                id="brief"
                name="brief"
                rows="4"
                class="field-input resize-none"
                placeholder="Share as much or as little as you'd like — program scope, timeline, challenges you're facing…"
              ></textarea>
            </div>

            <!-- Preferred follow-up -->
            <div class="field-group">
              <label for="followup" class="field-label">Preferred follow-up</label>
              <select id="followup" name="followup" class="field-input field-select">
                <option value="Email">Email</option>
                <option value="Call">Phone call</option>
                <option value="WhatsApp">WhatsApp</option>
                <option value="Video">Video call</option>
              </select>
            </div>

            <!-- Honeypot (hidden) -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>

            <div class="pt-2">
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex w-full items-center justify-center gap-2 rounded-pill bg-gradient-accent px-8 py-4 text-base font-semibold text-ink transition-all duration-300 hover:-translate-y-0.5 hover:shadow-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal focus-visible:outline-offset-3 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
              >
                <span id="submit-label">Request Briefing</span>
                <span aria-hidden="true" id="submit-arrow" class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
                <!-- Spinner (hidden until submitting) -->
                <svg id="submit-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
                </svg>
              </button>
              <p class="mt-3 text-xs text-cool">
                Your details are used only to respond to your enquiry. See our
                <a href="/privacy/" class="text-teal underline underline-offset-2 hover:text-cyan">Privacy Policy</a>.
              </p>
            </div>
          </form>
        </div>

        <!-- ── Sidebar ─────────────────────────────────── -->
        <aside class="space-y-6 lg:pt-10">
          <!-- Direct contact -->
          <div class="rounded-2xl border border-white/8 bg-white/[0.02] p-7">
            <h2 class="text-base font-semibold text-white">Direct contact</h2>
            <ul class="mt-5 space-y-4 text-sm">
              <li>
                <a
                  href="mailto:rami@emergedigital.com"
                  class="group flex items-start gap-3 text-platinum/70 transition hover:text-teal"
                >
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M2 4h12v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
                    <path d="M2 4l6 5 6-5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="break-all">rami@emergedigital.com</span>
                </a>
              </li>
              <li>
                <a
                  href="https://www.linkedin.com/company/emerge-digital/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center gap-3 text-platinum/70 transition hover:text-teal"
                >
                  <svg class="h-4 w-4 shrink-0 text-teal" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M13.5 1h-11A1.5 1.5 0 001 2.5v11A1.5 1.5 0 002.5 15h11a1.5 1.5 0 001.5-1.5v-11A1.5 1.5 0 0013.5 1zM5.5 12.5h-2v-6h2v6zm-1-7a1 1 0 110-2 1 1 0 010 2zm8 7h-2V9c0-.8-.7-1.5-1.5-1.5S7.5 8.2 7.5 9v3.5h-2v-6H7.5V7a3 3 0 016 0v5.5z"/>
                  </svg>
                  <span>LinkedIn — Emerge Digital</span>
                </a>
              </li>
              <li class="flex items-start gap-3 text-platinum/70">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M8 1.5A5.5 5.5 0 1113.5 7c0 3-5.5 7.5-5.5 7.5S2.5 10 2.5 7A5.5 5.5 0 018 1.5z" stroke="currentColor" stroke-width="1.25"/>
                  <circle cx="8" cy="7" r="1.5" fill="currentColor"/>
                </svg>
                <span>Dubai, UAE</span>
              </li>
              <li class="flex items-start gap-3 text-platinum/70">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
                  <path d="M8 4.5V8l2.5 1.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                </svg>
                <span>Sun–Thu, 09:00–18:00 GST</span>
              </li>
            </ul>
          </div>

          <!-- What to expect -->
          <div class="rounded-2xl border border-white/8 bg-white/[0.02] p-7">
            <h2 class="text-base font-semibold text-white">What to expect</h2>
            <ol class="mt-5 space-y-4">
              {[
                { n: '01', title: 'We respond within 1 business day', body: 'To confirm your briefing slot and send a short pre-read.' },
                { n: '02', title: 'A 30-minute conversation with Rami', body: 'No sales deck. A direct conversation about your program, your priorities, and how the local-prime model maps to both.' },
                { n: '03', title: 'A tailored follow-up within 48 hours', body: 'A Crawl-phase proposal or a capability map — whatever is most useful for your procurement timeline.' },
              ].map((step) => (
                <li class="flex items-start gap-4">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-teal/10 font-mono text-[11px] font-bold text-teal">
                    {step.n}
                  </span>
                  <div>
                    <p class="text-sm font-semibold text-white">{step.title}</p>
                    <p class="mt-0.5 text-sm leading-relaxed text-platinum/60">{step.body}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Compliance note -->
          <div class="rounded-xl border border-white/6 bg-white/[0.015] p-5 text-xs leading-relaxed text-cool">
            Emerge Digital — Dubai Mainland licensed entity. ESR & UBO compliant. GCC PDPL aligned.
          </div>
        </aside>

      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .field-label {
    @apply mb-2 block text-sm font-semibold text-platinum/85;
  }

  .field-input {
    @apply block w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white placeholder-cool/60 outline-none transition duration-200;
  }
  .field-input:focus {
    @apply border-teal/50 bg-white/[0.06];
    box-shadow: 0 0 0 3px rgba(0, 194, 199, 0.12);
  }
  .field-input.field-input--error {
    @apply border-danger/60;
    box-shadow: 0 0 0 3px rgba(229, 72, 77, 0.12);
  }

  .field-select {
    @apply cursor-pointer appearance-none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1l5 5 5-5' stroke='%236B7A90' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }
  .field-select option {
    background-color: #0A1F3D;
    color: #E8EEF5;
  }

  .field-error {
    @apply mt-1.5 text-xs text-danger;
  }

  /* Reason chip — checked state */
  .reason-chip input:checked + span {
    @apply border-teal/50 bg-teal/10 text-teal;
  }
  .reason-chip input:focus-visible + span {
    outline: 2px solid var(--color-teal);
    outline-offset: 2px;
    border-radius: 9999px;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successPanel = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitArrow = document.getElementById('submit-arrow');
  const submitSpinner = document.getElementById('submit-spinner');

  // Field validation helpers
  function getError(input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement): string {
    if (input.validity.valueMissing) return 'This field is required.';
    if (input.validity.typeMismatch && input.type === 'email') return 'Please enter a valid work email address.';
    return '';
  }

  function showError(fieldGroup: Element, message: string) {
    const errorEl = fieldGroup.querySelector<HTMLElement>('.field-error');
    const inputEl = fieldGroup.querySelector<HTMLElement>('.field-input');
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
    if (inputEl) inputEl.classList.add('field-input--error');
  }

  function clearError(fieldGroup: Element) {
    const errorEl = fieldGroup.querySelector<HTMLElement>('.field-error');
    const inputEl = fieldGroup.querySelector<HTMLElement>('.field-input');
    if (errorEl) {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
    if (inputEl) inputEl.classList.remove('field-input--error');
  }

  // Validate on blur
  form?.querySelectorAll<HTMLInputElement | HTMLSelectElement>('.field-input[required]').forEach((input) => {
    input.addEventListener('blur', () => {
      const group = input.closest('.field-group');
      if (!group) return;
      const error = getError(input);
      if (error) showError(group, error);
      else clearError(group);
    });
    input.addEventListener('input', () => {
      const group = input.closest('.field-group');
      if (!group) return;
      if (input.validity.valid) clearError(group);
    });
  });

  // Submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Client-side validation
    let valid = true;
    form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('.field-input[required]').forEach((input) => {
      const group = input.closest('.field-group');
      if (!group) return;
      const error = getError(input);
      if (error) {
        showError(group, error);
        valid = false;
      }
    });
    if (!valid) {
      const firstError = form.querySelector<HTMLElement>('.field-input--error');
      firstError?.focus();
      return;
    }

    // Honeypot check
    const honeypot = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
    if (honeypot?.value) return;

    // Loading state
    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Sending…';
    if (submitArrow) submitArrow.classList.add('hidden');
    if (submitSpinner) submitSpinner.classList.remove('hidden');

    try {
      const data = new FormData(form);

      // POST to a Cloudflare Worker endpoint or any form backend.
      // The action URL below is a placeholder — replace with your endpoint
      // (e.g. a Cloudflare Worker, Formspree, or similar).
      // For now we simulate success so the UX is testable end-to-end.
      const endpoint = form.dataset.endpoint ?? '';

      if (endpoint) {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error('Network response was not ok');
      } else {
        // No endpoint configured — simulate 600ms delay then succeed
        await new Promise((r) => setTimeout(r, 600));
      }

      // Show success panel
      form.style.display = 'none';
      if (successPanel) {
        successPanel.classList.remove('hidden');
        successPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    } catch {
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'Request Briefing';
      if (submitArrow) submitArrow.classList.remove('hidden');
      if (submitSpinner) submitSpinner.classList.add('hidden');

      // Surface a general error — avoid losing the user's work
      const errorBanner = document.createElement('p');
      errorBanner.className = 'rounded-xl border border-danger/40 bg-danger/5 px-5 py-3 text-sm text-danger';
      errorBanner.textContent = 'Something went wrong. Please try again or email rami@emergedigital.com directly.';
      form.insertBefore(errorBanner, form.firstChild);
      setTimeout(() => errorBanner.remove(), 8000);
    }
  });
</script>
