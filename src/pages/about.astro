---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

const principles = [
  {
    n: '01',
    title: 'Founder-led judgment.',
    body: 'Every engagement is structured and led at founder level. You get senior judgment from day one — not the second-tier account management typical of large global SIs.',
  },
  {
    n: '02',
    title: 'Local-prime accountability.',
    body: 'A single Dubai Mainland legal entity owns the contract, the invoices, and the compliance obligations across the GCC. One counterparty. No offshore proxies.',
  },
  {
    n: '03',
    title: 'CX as the moat.',
    body: 'The MEA enterprises that win the next decade will win on customer experience. Every capability we deploy — data, AI, cloud — is oriented toward that thesis.',
  },
  {
    n: '04',
    title: 'Crawl–Walk–Run pacing.',
    body: 'No oversized first contracts. We start with a focused diagnostic, earn the right to scale, and structure each phase with clear gates and measurable outcomes.',
  },
  {
    n: '05',
    title: 'Outcome contracts.',
    body: 'Named KPIs, phase gates, and transparent reporting at every stage. We structure engagements so accountability is built in — not negotiated after the fact.',
  },
];

const modelPillars = [
  {
    eyebrow: 'Commercial engine',
    title: 'Emerge Digital — The Local Prime',
    body: 'Emerge Digital is the independently registered Dubai Mainland entity that owns the client relationship, structures the engagement, signs the contract, and carries full commercial and compliance responsibility across the GCC. One throat to choke. One MEA-licensed counterparty. Zero ambiguity for procurement.',
  },
  {
    eyebrow: '23 years of regional heritage',
    title: 'The Regional Delivery Bench',
    body: '23 years of leadership in digital analytics, customer experience, and growth across the Middle East. Standing as one of only four Global Google Marketing Platform Partners worldwide. A GCC-native bench across analytics, MarTech, CX strategy, and commerce — operating across Dubai, Riyadh, Cairo, and beyond.',
  },
  {
    eyebrow: '80,000+ engineers worldwide',
    title: 'The Global Engineering Network',
    body: 'A global engineering footprint spanning Asia, Europe, and the Americas plugs in behind every engagement. Enterprise-grade application modernisation, cloud, AI engineering, and managed services capacity flow into MEA programs at the scale only a true global SI can offer.',
  },
];

const compliance = [
  { label: 'Jurisdiction', value: 'Dubai Mainland' },
  { label: 'Compliance', value: 'ESR & UBO compliant' },
  { label: 'Data handling', value: 'GCC PDPL aligned' },
  { label: 'Certification', value: 'ISO-aligned delivery network' },
];
---

<BaseLayout
  title="About Emerge Digital — Built in MEA for the Vision 2030 Decade"
  description="Emerge Digital is the Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation across MEA. Founded by Rami, backed by 23 years of regional heritage and 80,000+ engineers."
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-hero py-section-sm md:py-section">
    <div class="pointer-events-none absolute inset-0 bg-grid bg-grid-fade" aria-hidden="true"></div>
    <div class="aurora pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>

    <Container>
      <div class="max-w-3xl">
        <div class="chip-eyebrow mb-6">
          <span class="pulse-dot" aria-hidden="true"></span>
          Our Story
        </div>
        <h1 class="text-display-xl text-white">
          Built in MEA.<br />
          <span class="text-gradient-accent">Engineered for the Vision 2030 decade.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lead text-platinum/75">
          Emerge Digital was founded as a Dubai Mainland entity to do one thing exceptionally well:
          serve as the agile local prime for enterprise CX, Data, AI, and digital transformation
          programs across the MEA region — channelling 23 years of regional heritage and a global
          engineering network of 80,000+ engineers through a single, accountable contracting partner.
        </p>
      </div>
    </Container>
  </section>

  <!-- ── Founder's Letter ──────────────────────────────────── -->
  <section class="bg-ink py-section-sm md:py-section">
    <Container>
      <div class="grid gap-16 lg:grid-cols-[1fr_360px]">
        <!-- Letter -->
        <div>
          <Eyebrow class="mb-6" data-reveal>A note from our founder</Eyebrow>
          <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">A note from Rami, Founder</h2>

          <div class="mt-10 space-y-6 text-lead leading-relaxed text-platinum/75">
            <p data-reveal data-reveal-delay="2">
              When I founded Emerge Digital, the brief was simple: enterprise buyers in our region
              were tired of choosing between offshore mega-consultancies that didn't really show up
              locally, and small in-region agencies that couldn't deliver at the scale Vision 2030
              demands. I wanted to build the third option — a Dubai Mainland prime that owns the
              contract, the relationship, and the accountability, with the full bench of one of the
              Middle East's most respected analytics consultancies and one of the world's largest
              engineering organisations behind it.
            </p>
            <p data-reveal data-reveal-delay="3">
              Since then, we've delivered programs across the Gulf and Egypt under that thesis.
              Today Emerge stands on 23 years of regional heritage and a global engineering network
              of 80,000+ engineers — giving us the depth to match our in-country accountability.
              I personally lead the CX Division — Customer Experience, MarTech, and Commerce —
              because that's where I believe the next decade of competitive advantage will be won.
              Everything else we do reinforces that thesis.
            </p>
          </div>

          <div class="mt-10 flex items-center gap-4" data-reveal data-reveal-delay="4">
            <div class="h-12 w-12 rounded-full bg-gradient-accent"></div>
            <div>
              <p class="font-semibold text-white">Rami</p>
              <p class="text-sm text-cool">Founder, Emerge Digital</p>
            </div>
          </div>
        </div>

        <!-- Stats panel -->
        <div class="flex flex-col gap-4 self-start lg:pt-16">
          {[
            { value: '23', suffix: ' yrs', label: 'Regional consulting heritage' },
            { value: '7', suffix: '', label: 'MEA offices across UAE, KSA, Egypt and beyond' },
            { value: '4', suffix: '', label: 'Global Google Marketing Platform Partners worldwide — we are one' },
            { value: '80K+', suffix: '', label: 'Engineers in our global delivery network' },
          ].map((stat, i) => (
            <div class="rounded-2xl border border-white/8 bg-white/[0.02] p-6" data-reveal data-reveal-delay={String(i + 1)}>
              <p class="font-display text-display-lg tabular-nums leading-none text-gradient-accent">
                {stat.value}<span class="text-display-md">{stat.suffix}</span>
              </p>
              <p class="mt-2 text-sm leading-relaxed text-cool">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- ── The Operating Model ───────────────────────────────── -->
  <section class="border-t border-white/8 bg-navy py-section-sm md:py-section">
    <Container>
      <div class="mb-16 max-w-2xl">
        <Eyebrow class="mb-4" data-reveal>The Operating Model</Eyebrow>
        <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">
          One commercial engine. Three sources of unfair advantage.
        </h2>
        <p class="mt-4 text-lead text-platinum/70" data-reveal data-reveal-delay="2">
          The local-prime model is the structural reason clients choose Emerge Digital over a
          direct engagement with a global SI or a regional-only consultancy.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {modelPillars.map((pillar, i) => (
          <div class="card-surface flex flex-col gap-4 p-8" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-teal/60">
              0{i + 1}
            </span>
            <Eyebrow tone="cool" as="span">{pillar.eyebrow}</Eyebrow>
            <h3 class="text-display-md text-white">{pillar.title}</h3>
            <p class="flex-1 text-sm leading-relaxed text-platinum/65">{pillar.body}</p>
          </div>
        ))}
      </div>

      <!-- Model diagram — simplified text-based flow -->
      <div class="mt-16 rounded-2xl border border-white/8 bg-white/[0.015] p-8">
        <p class="mb-8 text-center text-eyebrow uppercase text-cool">How the model flows</p>
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm">
          {[
            { label: 'Client', sub: 'Enterprise buyer, GCC / MEA', accent: false },
            { label: '→', sub: '', accent: false, divider: true },
            { label: 'Emerge Digital', sub: 'Local Prime · Dubai Mainland · Single contract', accent: true },
            { label: '→', sub: '', accent: false, divider: true },
            { label: 'Regional bench', sub: '23 yrs heritage · 7 offices', accent: false },
            { label: '+', sub: '', accent: false, divider: true },
            { label: 'Global network', sub: '80,000+ engineers', accent: false },
          ].map((item) =>
            item.divider ? (
              <span class="text-cool">{item.label}</span>
            ) : (
              <div class:list={['rounded-xl border p-4 text-center', item.accent ? 'border-teal/40 bg-teal/8' : 'border-white/8 bg-white/[0.02]']}>
                <p class:list={['font-semibold', item.accent ? 'text-teal' : 'text-white']}>{item.label}</p>
                {item.sub && <p class="mt-1 text-[11px] leading-snug text-cool">{item.sub}</p>}
              </div>
            )
          )}
        </div>
        <p class="mt-8 text-center text-sm text-cool">
          Unified enterprise outcomes — delivered under a single Dubai Mainland contract.
        </p>
      </div>
    </Container>
  </section>

  <!-- ── Operating Principles ──────────────────────────────── -->
  <section class="border-t border-white/8 bg-ink py-section-sm md:py-section">
    <Container>
      <div class="mb-16 max-w-2xl">
        <Eyebrow class="mb-4" data-reveal>How we operate</Eyebrow>
        <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">Our operating principles.</h2>
        <p class="mt-4 text-lead text-platinum/70" data-reveal data-reveal-delay="2">
          Five commitments that are non-negotiable on every engagement.
        </p>
      </div>

      <div class="grid gap-px bg-white/8 sm:grid-cols-2 lg:grid-cols-3 rounded-2xl overflow-hidden border border-white/8">
        {principles.map((p, i) => (
          <div class="group bg-ink p-8 transition-colors duration-300 hover:bg-navy/60" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <p class="font-mono text-xs font-semibold text-teal/50">{p.n}</p>
            <h3 class="mt-4 text-lg font-semibold text-white">{p.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-platinum/60">{p.body}</p>
          </div>
        ))}
        <!-- Sixth cell — CTA -->
        <div class="bg-ink p-8 flex flex-col justify-between gap-6">
          <div>
            <p class="font-mono text-xs font-semibold text-cool/40">06</p>
            <h3 class="mt-4 text-lg font-semibold text-white">See the principles in practice.</h3>
            <p class="mt-3 text-sm leading-relaxed text-platinum/60">
              Read our case studies to see how each principle shows up in real program delivery.
            </p>
          </div>
          <Button href="/case-studies" variant="ghost" size="md">View case studies</Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- ── Compliance & Trust ─────────────────────────────────── -->
  <section class="border-t border-white/8 bg-navy py-section-sm md:py-section">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <Eyebrow class="mb-4" data-reveal>Compliance & Licensing</Eyebrow>
          <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">
            Procurement-ready from day one.
          </h2>
          <p class="mt-4 text-lead text-platinum/70" data-reveal data-reveal-delay="2">
            Emerge Digital is structured for enterprise procurement. Dubai Mainland incorporation,
            ESR and UBO compliance, and data-handling frameworks aligned to GCC PDPL — the
            compliance questions enterprise buyers ask first are already answered.
          </p>
          <Button href="/contact" class="mt-8" data-reveal data-reveal-delay="3">Talk to Rami</Button>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {compliance.map((item, i) => (
            <div class="rounded-2xl border border-white/8 bg-white/[0.02] p-6" data-reveal data-reveal-delay={String(i + 1)}>
              <p class="text-eyebrow uppercase text-cool">{item.label}</p>
              <p class="mt-2 font-semibold text-white">{item.value}</p>
            </div>
          ))}
          <div class="col-span-2 rounded-2xl border border-teal/20 bg-teal/5 p-6">
            <p class="text-sm text-platinum/70">
              ISO and security alignment across our global delivery network. Data residency and
              regional data-handling commitments available on request.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ── Final CTA ─────────────────────────────────────────── -->
  <section class="border-t border-white/8 bg-ink py-section-sm md:py-section">
    <Container>
      <div class="flex flex-col items-center gap-6 text-center">
        <Eyebrow data-reveal>Start the conversation</Eyebrow>
        <h2 class="text-display-lg max-w-xl text-white" data-reveal data-reveal-delay="1">Ready to talk Vision 2030?</h2>
        <p class="max-w-xl text-lead text-platinum/70" data-reveal data-reveal-delay="2">
          Book a 30-minute Readiness Briefing with Rami. We'll map your priorities to the
          2026–2027 procurement window and show you how the local-prime model works in practice.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/contact" size="lg">Book a Vision 2030 Readiness Briefing</Button>
          <Button href="/services" variant="secondary" size="lg">Explore the capability stack</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
