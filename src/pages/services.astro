        )}
      </Container>
    </section>
  ))}

  <!-- ── Crawl–Walk–Run callout ────────────────────────────── -->
  <section class="relative isolate overflow-hidden border-t border-white/[0.06] bg-ink py-section-sm md:py-section">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 55% 40% at 50% 50%, rgba(0,194,199,0.06), transparent 70%); filter: blur(60px);"></div>

    <Container class="relative">
      <div class="grid gap-14 lg:grid-cols-2 lg:items-center">
        <div>
          <Eyebrow class="mb-4" data-reveal>How we engage</Eyebrow>
          <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">
