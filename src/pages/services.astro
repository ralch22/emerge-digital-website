</BaseLayout>

<script>
  // Mouse-tracked glow on service cards
  document.querySelectorAll<HTMLElement>('.service-card-premium').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${((e.clientX - rect.left) / rect.width)  * 100}%`);
      card.style.setProperty('--my', `${((e.clientY - rect.top)  / rect.height) * 100}%`);
    });
  });

  // Reveal top accent bar on hover
  document.querySelectorAll<HTMLElement>('.service-card-premium').forEach((card) => {
    const bar = card.querySelector<HTMLElement>('.absolute.inset-x-0.top-0');
    if (!bar) return;
    card.addEventListener('mouseenter', () => bar.style.transform = 'scaleX(1)');
    card.addEventListener('mouseleave', () => bar.style.transform = 'scaleX(0)');
  });
</script>

<style>
  @keyframes aurora-drift {
    0%, 100% { transform: translate3d(0,0,0) scale(1); opacity: 0.85; }
    50%       { transform: translate3d(2%,-3%,0) scale(1.06); opacity: 1; }
  }
  @keyframes ping-slow {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50%       { transform: scale(1.7); opacity: 0; }
  }
</style>
