---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

interface Service {
  title: string;
  body: string;
  platforms?: string[];
  icon: string;
}

interface Pillar {
  id: string;
  eyebrow: string;
  headline: string;
  lead: string;
  note?: string;
  accentColor: string;
  icon: string;
  services: Service[];
}

const pillars: Pillar[] = [
  {
    id: 'cx',
    eyebrow: 'Customer Experience · CX Division',
    headline: 'Customer Experience',
    lead: 'The pillar Rami leads personally. Where the next decade of competitive advantage is won — and where Emerge Digital has the deepest conviction.',
    note: 'Led by Rami, Founder',
    accentColor: 'from-teal/20 to-teal/5',
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="8" r="4"/>
      <path d="M3 20c0-5 3.5-7 8-7s8 2 8 7"/>
      <path d="M16 3l2.5 2.5L22 2"/>
    </svg>`,
    services: [
      {
        title: 'CX Strategy & Design',
        body: 'CX vision setting, journey design, service blueprints, voice-of-customer frameworks, and CX operating models. We build the strategy layer before a single technology is deployed.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="9" r="3"/>
          <circle cx="9" cy="9" r="7.5"/>
          <line x1="9" y1="1.5" x2="9" y2="4"/>
          <line x1="9" y1="14" x2="9" y2="16.5"/>
          <line x1="1.5" y1="9" x2="4" y2="9"/>
          <line x1="14" y1="9" x2="16.5" y2="9"/>
        </svg>`,
      },
      {
        title: 'MarTech & Customer Data Orchestration (CDP)',
        body: 'CDP selection and implementation across Salesforce Data Cloud, Adobe Real-Time CDP, Tealium, mParticle, and Treasure Data. Identity resolution, real-time activation, consent and preference management.',
        platforms: ['Salesforce', 'Adobe', 'Tealium', 'mParticle'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="3.5" cy="5" r="2"/>
          <circle cx="14.5" cy="5" r="2"/>
          <circle cx="9" cy="14" r="2"/>
          <path d="M5.5 5h7M11.5 6.5l-2.5 5.5M6.5 6.5L9 12"/>
        </svg>`,
      },
      {
        title: 'Commerce & Platform Development',
        body: 'Headless and composable commerce architectures. Salesforce Commerce Cloud, Adobe Commerce, Shopify Plus enterprise builds. Marketplace strategy and digital retail operations.',
        platforms: ['Salesforce', 'Adobe Commerce', 'Shopify Plus'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h2l2.4 9h7.2L16 6H5.5"/>
          <circle cx="7.5" cy="15" r="1.2"/>
          <circle cx="13.5" cy="15" r="1.2"/>
        </svg>`,
      },
    ],
  },
  {
    id: 'data',
    eyebrow: 'Data & Analytics',
    headline: 'Data & Analytics',
    lead: 'Where our 23 years of regional analytics heritage shows up. From tag governance to predictive models — the data foundation that makes every other capability work.',
    accentColor: 'from-cyan/20 to-cyan/5',
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 16l5-5 4 4 5-8 4 3"/>
      <rect x="3" y="3" width="16" height="16" rx="2"/>
    </svg>`,
    services: [
      {
        title: 'Digital Analytics & Data Science',
        body: 'GA4 and GTM programs, BigQuery and Snowflake architectures, marketing mix modelling, attribution, predictive analytics, and CLV modelling. Built for MEA data volumes and GCC PDPL requirements.',
        platforms: ['GA4', 'BigQuery', 'Snowflake', 'Looker'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 13l4-5 3.5 3.5 4-6 4 2.5"/>
          <path d="M2 16h14"/>
        </svg>`,
      },
      {
        title: 'Data & Tag Governance',
        body: 'Tag management strategy, server-side tagging, consent frameworks (GCC PDPL, GDPR, CCPA), data lineage, and data quality programs. We build governance layers that hold up under regulatory scrutiny.',
        platforms: ['GTM Server-Side', 'OneTrust', 'Cookiebot'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 2l6 2.5v5C15 13 12 16 9 17 6 16 3 13 3 9.5v-5L9 2z"/>
          <path d="M6.5 9l2 2 3-3"/>
        </svg>`,
      },
      {
        title: 'Media & AdTech Excellence',
        body: 'Google Marketing Platform implementations — DV360, SA360, CM360 — building on our standing as one of only four Global GMP Partners worldwide. Trade-desk strategies, retail media networks, and MarTech–AdTech integration.',
        platforms: ['DV360', 'SA360', 'CM360', 'Meta', 'Snap'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9h2l2-5 3 10 2-6 1.5 3H15"/>
          <circle cx="15.5" cy="9" r="1.5" fill="currentColor" stroke="none"/>
        </svg>`,
      },
    ],
  },
  {
    id: 'ai',
    eyebrow: 'AI & Generative Solutions',
    headline: 'AI & Generative Solutions',
    lead: 'Applied where it moves a number — not as a positioning statement. Senior teams pair with governed AI agents to deliver measurable commercial and operational outcomes, with the return tracked on a live ROAI dashboard.',
    accentColor: 'from-teal-glow/20 to-teal-glow/5',
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="3"/>
      <path d="M11 2v3M11 17v3M2 11h3M17 11h3M4.9 4.9l2.1 2.1M14.9 14.9l2.2 2.2M4.9 17.1l2.1-2.1M14.9 7.1l2.2-2.2"/>
    </svg>`,
    services: [
      {
        title: 'Enterprise GenAI',
        body: 'Use-case discovery, RAG architectures, LLM evaluation frameworks, and copilot development for customer service, marketing operations, and internal productivity. Arabic and English LLM support.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="14" height="10" rx="2"/>
          <path d="M6 8h6M6 11h4"/>
          <path d="M12 14l2 3"/>
        </svg>`,
      },
      {
        title: 'AI for CX & Personalisation',
        body: 'AI-driven segmentation, real-time next-best-action engines, generative content systems, and conversational AI in Arabic and English. Deployed into CDP and CRM activation layers.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 2l1.5 4.5L15 8l-4.5 1.5L9 14l-1.5-4.5L3 8l4.5-1.5z"/>
          <path d="M14.5 12.5l.7 2 2 .7-2 .7-.7 2-.7-2-2-.7 2-.7z" fill="currentColor" stroke="none" opacity="0.7"/>
        </svg>`,
      },
      {
        title: 'AI Governance & Trust',
        body: 'Responsible AI frameworks, model risk management, GCC-aligned policy design, and hallucination and bias control. The governance layer that gives enterprise boards confidence to deploy.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 1.5l6 2.5v5.5c0 3.5-2.5 6.5-6 7.5-3.5-1-6-4-6-7.5V4z"/>
          <path d="M6 9l2 2 4-4"/>
        </svg>`,
      },
      {
        title: 'Agent Delivery Pods',
        body: 'Managed AI coding-agent pods on your repositories: every change developed in an isolated worktree, iterated against your own CI, and merged only through a human senior-engineer review gate. Run daily on Emerge’s own 11-repo portfolio.',
        platforms: ['GitHub', 'CI/CD'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6.5 5L3 9l3.5 4M11.5 5L15 9l-3.5 4"/>
          <path d="M9.8 3.5l-1.6 11"/>
        </svg>`,
      },
    ],
  },
  {
    id: 'transformation',
    eyebrow: 'Digital Transformation',
    headline: 'Digital Transformation',
    lead: 'The global technology group of 80,000+ behind enterprise-scale modernisation. From legacy-to-cloud migrations to managed services that run at production scale.',
    accentColor: 'from-teal/15 to-cyan/5',
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 14H4a4 4 0 0 1 0-8 5 5 0 0 1 9.7-1.5A4.5 4.5 0 0 1 18 9"/>
      <path d="M12 14l3 3 3-3M15 11v6"/>
    </svg>`,
    services: [
      {
        title: 'Enterprise Application Modernisation',
        body: 'Legacy mainframe and ERP modernisation, microservices migrations, cloud-native rebuilds, and API-led architectures. Sequenced for zero-disruption to live operations.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9a6 6 0 0 1 6-6 6 6 0 0 1 5.2 3"/>
          <path d="M15 9a6 6 0 0 1-6 6 6 6 0 0 1-5.2-3"/>
          <path d="M14 6l1.2-3 3 1.2"/>
          <path d="M4 12l-1.2 3-3-1.2"/>
        </svg>`,
      },
      {
        title: 'Cloud & Platform Engineering',
        body: 'Hyperscaler migrations and builds on AWS, Azure, and GCP. Platform engineering, DevSecOps, FinOps, and regional data residency programs aligned to GCC regulatory requirements.',
        platforms: ['AWS', 'Azure', 'GCP'],
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 12H3a4 4 0 0 1 0-8 5 5 0 0 1 9.3-1A4 4 0 0 1 15 8.5"/>
          <rect x="7" y="11" width="8" height="5" rx="1.5"/>
          <path d="M9 11V9M13 11V9"/>
        </svg>`,
      },
      {
        title: 'Managed Services & Run',
        body: '24/7 operations across MarTech, analytics, and application estates. AIOps-enabled service delivery, evergreen modernisation, and run-state governance — under the local-prime accountability model.',
        icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="9" r="2.5"/>
          <path d="M9 2v2M9 14v2M2 9h2M14 9h2M4 4l1.5 1.5M12.5 12.5L14 14M4 14l1.5-1.5M12.5 5.5L14 4"/>
        </svg>`,
      },
    ],
  },
];
---

<BaseLayout
  title="Services — Emerge Digital Capability Stack"
  description="From CX strategy to enterprise modernisation — Emerge Digital's full capability stack across Customer Experience, Data & Analytics, AI, and Digital Transformation. All under one Dubai Mainland contract."
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative isolate overflow-hidden bg-gradient-hero py-section-sm md:py-section">
    <!-- Decorative layers -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-grid bg-grid-fade"></div>
    <div aria-hidden="true" class="aurora-strong pointer-events-none absolute inset-0 opacity-70" style="animation: aurora-drift 24s ease-in-out infinite;"></div>
    <div aria-hidden="true" class="noise pointer-events-none absolute inset-0"></div>
    <div aria-hidden="true" class="beam-scan pointer-events-none absolute inset-0"></div>

    <Container class="relative">
      <div class="max-w-3xl">
        <div class="chip-eyebrow-teal mb-6" data-reveal>
          <span class="pulse-dot" aria-hidden="true"></span>
          The Full Capability Stack
        </div>
        <h1 class="text-display-xl text-white" data-reveal data-reveal-delay="1">
          From CX strategy to<br />
          <span class="text-gradient-accent">enterprise modernisation</span> —<br />
          under one local prime.
        </h1>
        <p class="mt-6 max-w-2xl text-lead text-platinum/75" data-reveal data-reveal-delay="2">
          Emerge Digital structures and delivers programs across four capability pillars. Our
          founder personally leads the CX Division. The remaining pillars are delivered through our
          23-year regional bench and global engineering network — all under a single Dubai Mainland
          contract.
        </p>
      </div>

      <!-- Pillar nav pills -->
      <nav class="mt-12 flex flex-wrap gap-3" aria-label="Jump to capability pillar" data-reveal data-reveal-delay="3">
        {pillars.map((p) => (
          <a
            href={`#${p.id}`}
            class="rounded-pill border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-platinum/70 backdrop-blur transition-all duration-300 hover:border-teal/40 hover:bg-teal/[0.08] hover:text-teal"
          >
            {p.headline}
          </a>
        ))}
      </nav>

      <!-- Trust badges -->
      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3" data-reveal data-reveal-delay="4">
        {['Dubai Mainland · ESR & UBO Compliant', 'GCC PDPL Aligned', '23 years regional heritage', '1 of 4 Global GMP Partners'].map((t) => (
          <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-eyebrow text-cool">
            <div class="h-1 w-1 rounded-full bg-teal/50"></div>
            {t}
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ── Pillars ───────────────────────────────────────────── -->
  {pillars.map((pillar, i) => (
    <section
      id={pillar.id}
      class:list={[
        'relative isolate overflow-hidden border-t border-white/[0.06] py-section-sm md:py-section',
        i % 2 === 0 ? 'bg-ink' : 'bg-navy',
      ]}
    >
      <!-- Subtle radial glow per section -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0"
        style={`background: radial-gradient(ellipse 50% 40% at ${i % 2 === 0 ? '80%' : '20%'} 50%, rgba(0,194,199,0.05), transparent 70%); filter: blur(60px);`}
      ></div>

      <Container class="relative">
        <!-- Pillar header -->
        <div class="mb-14 grid gap-10 lg:grid-cols-[auto_1fr] lg:items-start">
          <!-- Icon + labels -->
          <div class="flex flex-col gap-4 lg:pt-1 lg:w-72">
            <div class="icon-wrap icon-wrap-lg" set:html={pillar.icon}></div>
            <Eyebrow data-reveal>{pillar.eyebrow}</Eyebrow>
            <h2 class="text-display-lg text-white" data-reveal data-reveal-delay="1">{pillar.headline}</h2>
            {pillar.note && (
              <span class="inline-flex w-fit items-center gap-2 rounded-pill border border-teal/25 bg-teal/[0.08] px-3 py-1.5 text-xs font-semibold text-teal" data-reveal data-reveal-delay="2">
                <svg class="h-2.5 w-2.5 fill-teal" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="4"/></svg>
                {pillar.note}
              </span>
            )}
          </div>
          <!-- Lead -->
          <p class="self-center text-lead text-platinum/70 lg:pt-14" data-reveal data-reveal-delay="2">{pillar.lead}</p>
        </div>

        <!-- Service cards -->
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {pillar.services.map((svc, si) => (
            <div
              class="service-card-premium card-surface flex flex-col gap-0 overflow-hidden"
              data-reveal
              data-reveal-delay={String(si + 1)}
            >
              <!-- Top accent bar -->
              <div class="absolute inset-x-0 top-0 h-[1.5px] origin-left scale-x-0 bg-gradient-accent transition-transform duration-500 ease-out-quint group-hover:scale-x-100 pointer-events-none" style="transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);"></div>

              <div class="flex flex-col gap-4 p-7">
                <!-- Icon -->
                <div class="icon-wrap" set:html={svc.icon}></div>

                <h3 class="text-lg font-semibold leading-snug text-white">{svc.title}</h3>
                <p class="flex-1 text-sm leading-relaxed text-platinum/65">{svc.body}</p>

                {svc.platforms && (
                  <div class="flex flex-wrap gap-1.5 pt-1">
                    {svc.platforms.map((plat) => (
                      <span class="rounded border border-white/8 bg-white/[0.03] px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wide text-cool transition-colors duration-300 group-hover:border-teal/20 group-hover:text-platinum/80">
                        {plat}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>

        {pillar.id === 'cx' && (
          <a
            href="/services/private-ai-cx/"
            class="private-cx-card group relative mt-5 flex flex-col gap-6 overflow-hidden rounded-card border border-teal/25 p-8 transition-all duration-400 hover:border-teal/50 hover:-translate-y-0.5 md:flex-row md:items-center md:gap-10"
            style="background: linear-gradient(120deg, rgba(0,194,199,0.10), rgba(61,220,227,0.04));"
            data-reveal
          >
            <!-- Top accent bar -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[1.5px] origin-left scale-x-0 bg-gradient-accent transition-transform duration-500 ease-out-quint group-hover:scale-x-100" style="transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);"></div>

            <div class="flex-1">
              <span class="inline-flex w-fit items-center gap-2 rounded-pill border border-teal/30 bg-teal/[0.10] px-3 py-1 text-[11px] font-semibold uppercase tracking-eyebrow text-teal">
                New Service Line
              </span>
              <h3 class="mt-4 text-display-md text-white">
                Private AI CX <span class="text-gradient-accent">Assistant</span>
              </h3>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-platinum/70">
                A production multimodal CX agent on an honest sovereignty ladder — Gemini on Vertex
                AI, open weights you own inside your own cloud project, or fully on-premise. Built
                for government-adjacent, healthcare, and BFSI programs where "where does the data
                live?" is the first question. In-country KSA deployment verified.
              </p>
            </div>

            <div class="flex shrink-0 items-center gap-2 self-start rounded-pill bg-gradient-accent px-5 py-2.5 text-sm font-semibold text-ink transition-all duration-300 group-hover:shadow-glow md:self-auto">
              Explore the offer
              <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5">
                <path d="M2 6h8M6.5 2.5 10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        )}

        {pillar.id === 'ai' && (
          <a
            href="https://future.emergedigital.com?utm_source=vision&utm_medium=practice"
            target="_blank"
            rel="noopener noreferrer"
            class="agentforce-card group relative mt-5 flex flex-col gap-6 overflow-hidden rounded-card border border-teal/25 p-8 transition-all duration-400 hover:border-teal/50 hover:-translate-y-0.5 md:flex-row md:items-center md:gap-10"
            style="background: linear-gradient(120deg, rgba(0,194,199,0.10), rgba(61,220,227,0.04));"
            data-reveal
          >
            <!-- Top accent bar -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[1.5px] origin-left scale-x-0 bg-gradient-accent transition-transform duration-500 ease-out-quint group-hover:scale-x-100" style="transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);"></div>

            <div class="flex-1">
              <span class="inline-flex w-fit items-center gap-2 rounded-pill border border-teal/30 bg-teal/[0.10] px-3 py-1 text-[11px] font-semibold uppercase tracking-eyebrow text-teal">
                Named Practice
              </span>
              <h3 class="mt-4 text-display-md text-white">
                Agentforce <span class="text-gradient-accent">practice</span>
              </h3>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-platinum/70">
                Our dedicated Agentforce practice — the named agentic-AI capability operating under
                the Emerge Digital corporate umbrella. Forward-deployed, governed AI agents for enterprise CX,
                service, and operations — measured on outcomes, delivered with the same local-prime accountability.
              </p>
            </div>

            <div class="flex shrink-0 items-center gap-2 self-start rounded-pill bg-gradient-accent px-5 py-2.5 text-sm font-semibold text-ink transition-all duration-300 group-hover:shadow-glow md:self-auto">
              Explore the practice
              <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <path d="M4 2.5h5.5V8M9.5 2.5 3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        )}

        {pillar.id === 'ai' && (
          <a
            href="https://vault.emergedigital.com?utm_source=vision&utm_medium=practice&utm_campaign=vaultos"
            target="_blank"
            rel="noopener noreferrer"
            class="vaultos-card group relative mt-5 flex flex-col gap-6 overflow-hidden rounded-card border border-teal/25 p-8 transition-all duration-400 hover:border-teal/50 hover:-translate-y-0.5 md:flex-row md:items-center md:gap-10"
            style="background: linear-gradient(120deg, rgba(0,194,199,0.10), rgba(61,220,227,0.04));"
            data-reveal
          >
            <!-- Top accent bar -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[1.5px] origin-left scale-x-0 bg-gradient-accent transition-transform duration-500 ease-out-quint group-hover:scale-x-100" style="transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);"></div>

            <div class="flex-1">
              <span class="inline-flex w-fit items-center gap-2 rounded-pill border border-teal/30 bg-teal/[0.10] px-3 py-1 text-[11px] font-semibold uppercase tracking-eyebrow text-teal">
                Knowledge Product
              </span>
              <h3 class="mt-4 text-display-md text-white">
                OKF Knowledge Graph — <span class="text-gradient-accent">VaultOS</span>
              </h3>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-platinum/70">
                Structured, governed, agent-ready knowledge. VaultOS turns institutional knowledge into an
                OKF v0.1-compliant knowledge graph — encrypted, auditable, and built for BigQuery Knowledge
                Catalog and Vertex AI. Emerge runs its own operations on it: 327+ documents across 6 businesses.
              </p>
            </div>

            <div class="flex shrink-0 items-center gap-2 self-start rounded-pill bg-gradient-accent px-5 py-2.5 text-sm font-semibold text-ink transition-all duration-300 group-hover:shadow-glow md:self-auto">
              Explore VaultOS
