---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Stat from '../components/Stat.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Card from '../components/Card.astro';
import BrandIcon from '../components/BrandIcon.astro';

const colors = [
  { name: 'Deep Navy', hex: '#0A1F3D', class: 'bg-navy', token: 'navy', dark: true },
  { name: 'Midnight Ink', hex: '#06122A', class: 'bg-ink', token: 'ink', dark: true },
  { name: 'Slate Graphite', hex: '#1F2A3C', class: 'bg-slate', token: 'slate', dark: true },
  { name: 'Electric Teal', hex: '#00C2C7', class: 'bg-teal', token: 'teal', dark: false },
  { name: 'Signal Cyan', hex: '#3DDCE3', class: 'bg-cyan', token: 'cyan', dark: false },
  { name: 'Cool Grey', hex: '#6B7A90', class: 'bg-cool', token: 'cool', dark: true },
  { name: 'Soft Platinum', hex: '#E8EEF5', class: 'bg-platinum', token: 'platinum', dark: false },
  { name: 'Warm Off-White', hex: '#F7F9FC', class: 'bg-offwhite', token: 'offwhite', dark: false },
];

const gradients = [
  { name: 'Hero gradient', class: 'bg-gradient-hero', desc: 'navy → ink → teal-tint · backgrounds' },
  { name: 'Accent gradient', class: 'bg-gradient-accent', desc: 'teal → cyan · primary CTAs' },
  { name: 'Data-viz gradient', class: 'bg-gradient-data', desc: 'navy → teal · charts and journeys' },
];

const stats = [
  { value: '23 yrs', label: 'Regional consulting heritage' },
  { value: '7', label: 'MEA offices' },
  { value: '4', label: 'Global GMP partners worldwide' },
  { value: '80,000+', label: 'People in a global technology group' },
];
---

<BaseLayout
  title="Style Guide — Emerge Digital"
  description="Internal review surface for design primitives, tokens, and component variants."
>
  <Section tone="gradient">
    <Container>
      <Eyebrow>Design System</Eyebrow>
      <h1 class="mt-4 text-display-xl text-white">Emerge Digital — Style Guide</h1>
      <p class="mt-6 max-w-prose text-lead text-platinum/80">
        A live surface for every primitive in every variant. Use this page to verify
        tokens, spacing, and component behavior before touching marketing pages.
      </p>
      <div class="mt-8">
        <Button href="/" variant="secondary">Open the homepage</Button>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>Pages</Eyebrow>
      <h2 class="mt-3 text-display-lg">Built so far</h2>
      <ul class="mt-8 grid gap-4 md:grid-cols-2">
        <li class="rounded-card border border-white/10 bg-navy/40 p-6">
          <p class="text-eyebrow uppercase text-teal">Marketing</p>
          <h3 class="mt-3 text-display-md">Homepage</h3>
          <p class="mt-3 text-platinum/80">
            All nine sections from §3 of the strategy doc, wired with primitives.
          </p>
          <div class="mt-5">
            <Button href="/" variant="ghost">Open /</Button>
          </div>
        </li>
        <li class="rounded-card border border-white/10 bg-navy/40 p-6">
          <p class="text-eyebrow uppercase text-teal">Internal</p>
          <h3 class="mt-3 text-display-md">Style Guide</h3>
          <p class="mt-3 text-platinum/80">
            This page. Reviewed alongside the homepage to verify visual coherence.
          </p>
        </li>
      </ul>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>Brand mark</Eyebrow>
      <h2 class="mt-3 text-display-lg">The icon</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        The Emerge Digital mark via <code class="font-mono text-sm text-teal">BrandIcon</code>.
        Recoloured into the site palette — a teal&nbsp;→&nbsp;navy gradient tile with a white mark.
        Apply <code class="font-mono text-sm text-teal">rounded-lg overflow-hidden</code> + a size on the element.
      </p>
      <div class="mt-10 flex flex-wrap items-end gap-8">
        <div class="flex flex-col items-center gap-2">
          <BrandIcon class="h-8 w-8 rounded-lg overflow-hidden" />
          <span class="font-mono text-xs text-cool">h-8 · nav</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <BrandIcon class="h-12 w-12 rounded-xl overflow-hidden" />
          <span class="font-mono text-xs text-cool">h-12</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <BrandIcon class="h-20 w-20 rounded-2xl overflow-hidden" />
          <span class="font-mono text-xs text-cool">h-20</span>
        </div>
        <div class="flex items-center gap-2.5 rounded-card border border-white/10 bg-offwhite px-5 py-4">
          <BrandIcon class="h-8 w-8 rounded-lg overflow-hidden" />
          <span class="font-display text-lg font-semibold tracking-tight text-slate">Emerge<span class="text-teal">.</span></span>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>1 · Colors</Eyebrow>
      <h2 class="mt-3 text-display-lg">Brand palette</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        Tokens defined in <code class="font-mono text-sm text-teal">tailwind.config.mjs</code>
        and mirrored as CSS variables in <code class="font-mono text-sm text-teal">global.css</code>.
        Never hardcode these hex values in components.
      </p>
      <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-4">
        {
          colors.map((c) => (
            <div class="overflow-hidden rounded-card border border-white/10">
              <div class:list={[c.class, 'h-28 w-full']} />
              <div class="bg-navy/40 p-4">
                <p class="font-medium text-white">{c.name}</p>
                <p class="mt-1 font-mono text-xs text-cool">{c.hex}</p>
                <p class="mt-1 font-mono text-xs text-teal">{c.token}</p>
              </div>
            </div>
          ))
        }
      </div>

      <h3 class="mt-16 text-display-md">Signature gradients</h3>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {
          gradients.map((g) => (
            <div class="overflow-hidden rounded-card border border-white/10">
              <div class:list={[g.class, 'h-32 w-full']} />
              <div class="bg-navy/40 p-4">
                <p class="font-medium text-white">{g.name}</p>
                <p class="mt-1 font-mono text-xs text-cool">{g.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>2 · Typography</Eyebrow>
      <h2 class="mt-3 text-display-lg">Type scale</h2>
      <div class="mt-10 space-y-10 border-t border-white/5">
        <div class="grid gap-4 border-b border-white/5 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">text-display-xl</code>
          <p class="text-display-xl">Local Prime. Global Power.</p>
        </div>
        <div class="grid gap-4 border-b border-white/5 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">text-display-lg</code>
          <p class="text-display-lg">A risk-managed path to enterprise outcomes.</p>
        </div>
        <div class="grid gap-4 border-b border-white/5 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">text-display-md</code>
          <p class="text-display-md">One commercial engine. Three sources of advantage.</p>
        </div>
        <div class="grid gap-4 border-b border-white/5 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">text-lead</code>
          <p class="max-w-prose text-lead text-platinum/90">
            Emerge Digital is the agile Dubai Mainland prime for enterprise Customer
            Experience, Data, AI, and digital transformation programs across the MEA region.
          </p>
        </div>
        <div class="grid gap-4 border-b border-white/5 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">body (default)</code>
          <p class="max-w-prose text-platinum/90">
            Government, BFSI, and Retail leaders across the UAE, KSA, and Egypt are entering
            the most concentrated procurement window in the region's history. Vision 2030,
            the UAE's We the UAE 2031 agenda, and Egypt's Vision 2030 are converging into a
            single inflection point.
          </p>
        </div>
        <div class="grid gap-4 py-6 md:grid-cols-[160px_1fr] md:items-baseline">
          <code class="font-mono text-sm text-teal">text-eyebrow</code>
          <p class="text-eyebrow uppercase text-teal">Local Prime · Dubai Mainland · MEA-Wide Delivery</p>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>3 · Buttons</Eyebrow>
      <h2 class="mt-3 text-display-lg">Variants × sizes</h2>

      <div class="mt-10 space-y-10">
        <div>
          <p class="text-eyebrow uppercase text-cool">Primary</p>
          <div class="mt-4 flex flex-wrap items-center gap-4">
            <Button href="/contact/" size="md">Book a Vision 2030 Readiness Briefing</Button>
            <Button href="/contact/" size="lg">Book a Vision 2030 Readiness Briefing</Button>
            <Button href="/contact/" size="md" arrow={false}>No arrow</Button>
          </div>
        </div>

        <div>
          <p class="text-eyebrow uppercase text-cool">Secondary</p>
          <div class="mt-4 flex flex-wrap items-center gap-4">
            <Button variant="secondary" href="/services/" size="md">Explore the Capability Stack</Button>
            <Button variant="secondary" href="/services/" size="lg">Explore the Capability Stack</Button>
          </div>
        </div>

        <div>
          <p class="text-eyebrow uppercase text-cool">Ghost</p>
          <div class="mt-4 flex flex-wrap items-center gap-6">
            <Button variant="ghost" href="/about/" size="md">Read the full story</Button>
            <Button variant="ghost" href="/insights/" size="lg">See all success stories</Button>
            <Button variant="ghost" href="/contact/" size="md">Or send us a brief</Button>
          </div>
        </div>

        <div>
          <p class="text-eyebrow uppercase text-cool">As button (form submit)</p>
          <div class="mt-4 flex flex-wrap items-center gap-4">
            <Button as="button" type="submit">Request Briefing</Button>
            <Button as="button" type="submit" variant="secondary">Cancel</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>4 · Eyebrow</Eyebrow>
      <h2 class="mt-3 text-display-lg">Tones</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-card border border-white/10 bg-navy/40 p-6">
          <p class="font-mono text-xs text-cool">tone="teal" (default)</p>
          <Eyebrow tone="teal" class="mt-3">The 2026–2027 Window</Eyebrow>
        </div>
        <div class="rounded-card border border-white/10 bg-navy/40 p-6">
          <p class="font-mono text-xs text-cool">tone="cool"</p>
          <Eyebrow tone="cool" class="mt-3">Trusted Across MEA</Eyebrow>
        </div>
        <div class="rounded-card border border-white/10 bg-navy/40 p-6">
          <p class="font-mono text-xs text-cool">tone="white"</p>
          <Eyebrow tone="white" class="mt-3">How We Engage</Eyebrow>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>5 · Stats</Eyebrow>
      <h2 class="mt-3 text-display-lg">Homepage stat row</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        Real proof points pulled from the strategy doc. Use accent for hero placements,
        non-accent for secondary panels.
      </p>
      <div class="mt-10 grid grid-cols-2 gap-10 md:grid-cols-4">
        {stats.map((s) => <Stat value={s.value} label={s.label} />)}
      </div>
      <div class="mt-12 grid grid-cols-2 gap-10 md:grid-cols-4">
        {stats.map((s) => <Stat value={s.value} label={s.label} accent={false} />)}
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>6 · TrustStrip</Eyebrow>
      <h2 class="mt-3 text-display-lg">Credentials row</h2>
      <div class="mt-10 space-y-10">
        <TrustStrip
          prefix="Trusted Across"
          items={['Government', 'BFSI', 'Retail', 'GCC PDPL Aligned', 'ESR / UBO Compliant']}
        />
        <TrustStrip
          items={['Salesforce', 'Adobe', 'Tealium', 'Snowflake', 'BigQuery', 'AWS', 'Azure', 'GCP']}
        />
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>7 · Cards</Eyebrow>
      <h2 class="mt-3 text-display-lg">Card variants</h2>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <Card
          tone="dark"
          eyebrow="The Local Prime"
          title="In-country accountability"
        >
          <p class="text-platinum/80">
            The independently registered Dubai Mainland entity that owns the client
            relationship, structures the engagement, signs the contract, and carries full
            commercial and compliance responsibility. One throat to choke. Zero ambiguity
            for procurement.
          </p>
        </Card>
        <Card
          tone="dark"
          eyebrow="The Regional Heritage"
          title="23 years of MEA delivery"
        >
          <p class="text-platinum/80">
            23 years of regional analytics heritage. 7 offices across MEA. One of only four
            Global Google Marketing Platform Partners worldwide.
          </p>
        </Card>
        <Card
          tone="dark"
          eyebrow="The Global Engine"
          title="80,000+ people"
        >
          <p class="text-platinum/80">
            A worldwide engineering network across 30+ countries. Enterprise-grade
            modernization, cloud, AI engineering, and managed services capacity.
          </p>
        </Card>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <Card tone="light" eyebrow="BFSI · Customer Data Orchestration" title="Tier-1 GCC Bank">
          <p>
            Unified 14 fragmented customer data sources into a single CDP, enabling
            real-time personalization across digital and contact-center channels.
          </p>
          <p class="mt-4 font-semibold text-teal">+38% lift in cross-sell conversion · 6 months</p>
        </Card>
        <Card tone="light" eyebrow="Government · Citizen Experience" title="National Government Entity, KSA">
          <p>
            Designed and rolled out an end-to-end citizen experience operating model
            across 4 service portals, measured against the national CSAT benchmark.
          </p>
          <p class="mt-4 font-semibold text-teal">+22-point CSAT lift</p>
        </Card>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <Card tone="dark">
          <p class="text-platinum/80">Card with no header. Slot-only content for flexible composition.</p>
        </Card>
        <Card tone="dark" padded={false}>
          <div class="surface-hero rounded-card p-8">
            <p class="text-eyebrow uppercase text-teal">Padded={'{false}'}</p>
            <p class="mt-3 text-white">
              Use when the card itself is a media or gradient frame and the inner content
              owns its own padding.
            </p>
          </div>
        </Card>
      </div>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow>8 · Section tones</Eyebrow>
      <h2 class="mt-3 text-display-lg">Surface showcase</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        Section is the single source of vertical rhythm and surface tone. Below the
        page-bg, every Section preview is rendered at its natural padding and color.
      </p>
    </Container>
  </Section>

  <Section tone="dark">
    <Container>
      <Eyebrow tone="cool">tone="dark" (default)</Eyebrow>
      <h2 class="mt-3 text-display-md">The default surface</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        Used for the majority of marketing sections. Body sits on the brand ink with
        platinum text for readability.
      </p>
    </Container>
  </Section>

  <Section tone="light">
    <Container>
      <Eyebrow tone="cool">tone="light"</Eyebrow>
      <h2 class="mt-3 text-display-md text-slate">Light surface for contrast</h2>
      <p class="mt-3 max-w-prose text-slate">
        Use sparingly to break up long pages — typically a "proof" or "deeper-detail"
        section sandwiched between two dark surfaces.
      </p>
    </Container>
  </Section>

  <Section tone="gradient">
    <Container>
      <Eyebrow>tone="gradient"</Eyebrow>
      <h2 class="mt-3 text-display-md">The hero gradient surface</h2>
      <p class="mt-3 max-w-prose text-platinum/80">
        Reserved for the home hero and final CTA panels. Subtle navy → ink → teal-tint
        wash signals "premium enterprise."
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <Button href="/contact/">Book a Vision 2030 Readiness Briefing</Button>
        <Button variant="ghost" href="/contact/">Or send us a brief</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>
