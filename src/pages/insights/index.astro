---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Button from '../../components/Button.astro';

const allInsights = await getCollection('insights', ({ data }) => data.published);

// Sort newest first
const insights = allInsights.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const categories = ['All', 'Vision 2030 Brief', 'Capability POV', 'Report'] as const;

// Featured = most recent
const [featured, ...rest] = insights;

function formatDate(d: Date | string) {
  return new Date(d).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout
  title="Insights — Emerge Digital"
  description="Executive POVs, Vision 2030 briefs, and capability deep-dives from Emerge Digital — the Dubai Mainland local prime for enterprise CX, Data, AI, and digital transformation."
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-hero py-section-sm md:py-section">
    <div class="pointer-events-none absolute inset-0 bg-grid bg-grid-fade" aria-hidden="true"></div>
    <div class="aurora pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
    <Container>
      <div class="max-w-3xl">
        <div class="chip-eyebrow mb-6">
          <span class="pulse-dot" aria-hidden="true"></span>
          Insights
        </div>
        <h1 class="text-display-xl text-white">
          Thinking from the<br />
          <span class="text-gradient-accent">MEA frontier.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lead text-platinum/75">
          Vision 2030 briefs, capability POVs, and executive perspectives — written for the CXOs,
          CDOs, and procurement leaders navigating the 2026–2027 transformation window.
        </p>
      </div>
    </Container>
  </section>

  <!-- ── Featured article ───────────────────────────────── -->
  {featured && (
    <section class="bg-navy py-section-sm md:py-16">
      <Container>
        <Eyebrow class="mb-8" data-reveal>Featured</Eyebrow>
        <a
          href={`/insights/${featured.slug}`}
          class="card-surface group grid gap-8 p-8 no-underline md:grid-cols-[1fr_320px] lg:p-12"
          data-reveal
          data-reveal-delay="1"
          aria-label={`Read featured article: ${featured.data.title}`}
        >
          <div class="flex flex-col justify-between gap-6">
            <div>
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-pill border border-teal/25 bg-teal/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-teal">
                  {featured.data.category}
                </span>
                <time class="text-xs text-cool" datetime={new Date(featured.data.publishDate).toISOString()}>
                  {formatDate(featured.data.publishDate)}
                </time>
                {featured.data.readingMinutes && (
                  <span class="text-xs text-cool">{featured.data.readingMinutes} min read</span>
                )}
              </div>
              <h2 class="mt-4 text-display-lg text-white transition group-hover:text-teal">
                {featured.data.title}
              </h2>
              <p class="mt-4 text-lead text-platinum/65">{featured.data.summary}</p>
            </div>
            <div>
              <p class="mb-4 text-sm text-cool">{featured.data.author}</p>
              <div class="inline-flex items-center gap-2 text-sm font-semibold text-teal transition group-hover:gap-3">
                Read the article <span aria-hidden="true">→</span>
              </div>
            </div>
          </div>

          <!-- Article meta panel -->
          <div class="flex flex-col gap-4 self-start">
            <div class="rounded-xl border border-white/8 bg-white/[0.02] p-5">
              <p class="text-eyebrow uppercase text-cool">Topics covered</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {featured.data.tags.map((tag) => (
                  <span class="rounded border border-white/8 bg-white/[0.03] px-2 py-0.5 text-[10px] uppercase tracking-wide text-cool">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            {featured.data.gated && (
              <div class="rounded-xl border border-teal/20 bg-teal/5 p-5">
                <p class="text-sm font-semibold text-white">Gated report</p>
                <p class="mt-1.5 text-xs leading-relaxed text-platinum/60">
                  This content requires a brief registration to access the full report.
                </p>
              </div>
            )}
          </div>
        </a>
      </Container>
    </section>
  )}

  <!-- ── Filter + grid ─────────────────────────────────── -->
  <section class="bg-ink py-section-sm md:py-section">
    <Container>
      <!-- Filter bar -->
      <div
        class="mb-10 flex flex-wrap items-center gap-2"
        role="group"
        aria-label="Filter insights by category"
      >
        {categories.map((cat) => (
          <button
            class="filter-btn rounded-pill border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-wide text-platinum/70 transition hover:border-teal/50 hover:text-teal data-[active]:border-teal data-[active]:bg-teal/10 data-[active]:text-teal"
            data-value={cat}
            data-active={cat === 'All' ? '' : undefined}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <ul
        id="insights-grid"
        class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
        aria-label="Insights articles"
      >
        {rest.map((article, i) => (
          <li data-category={article.data.category} class="insight-card" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <a
              href={`/insights/${article.slug}`}
              class="card-surface group flex h-full flex-col gap-5 p-7 no-underline"
              aria-label={`Read: ${article.data.title}`}
            >
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-pill border border-teal/20 bg-teal/10 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-teal">
                  {article.data.category}
                </span>
                {article.data.gated && (
                  <span class="rounded-pill border border-warning/20 bg-warning/10 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-warning">
                    Gated
                  </span>
                )}
              </div>

              <h2 class="text-lg font-semibold leading-snug text-white transition group-hover:text-teal">
                {article.data.title}
              </h2>

              <p class="flex-1 text-sm leading-relaxed text-platinum/60">{article.data.summary}</p>

              <div class="flex items-center justify-between border-t border-white/6 pt-4">
                <div>
                  <p class="text-xs text-cool">{article.data.author}</p>
                  <time
                    class="text-xs text-cool"
                    datetime={new Date(article.data.publishDate).toISOString()}
                  >
                    {formatDate(article.data.publishDate)}
                    {article.data.readingMinutes && ` · ${article.data.readingMinutes} min`}
                  </time>
                </div>
                <div class="flex items-center gap-1 text-xs font-semibold text-teal transition group-hover:gap-2">
                  Read <span aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <p id="no-insights" class="hidden py-20 text-center text-cool">
        No articles match this category yet.
        <button class="text-teal underline" id="reset-filters">Show all</button>
      </p>
    </Container>
  </section>

  <!-- ── Newsletter / subscribe CTA ────────────────────── -->
  <section class="border-t border-white/8 bg-navy py-section-sm md:py-section">
    <Container>
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <Eyebrow class="mb-4">Stay informed</Eyebrow>
          <h2 class="text-display-lg text-white">
            Vision 2030 Briefings — direct to your inbox.
          </h2>
          <p class="mt-4 text-lead text-platinum/70">
            Short, executive-grade POVs on the GCC transformation window. No newsletters. No
            marketing cadences. Sent when we have something worth saying.
          </p>
        </div>

        <form
          name="insights-subscribe"
          class="flex flex-col gap-4 rounded-2xl border border-white/8 bg-white/[0.02] p-8"
          id="subscribe-form"
          novalidate
        >
          <input type="hidden" name="form-name" value="insights-subscribe" />
          <div class="flex flex-col gap-2">
            <label for="sub-email" class="text-sm font-semibold text-platinum/85">
              Work email <span class="text-teal" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="sub-email"
              name="email"
              required
              placeholder="you@company.com"
              class="block w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white placeholder-cool/60 outline-none transition duration-200 focus:border-teal/50 focus:bg-white/[0.06]"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="sub-name" class="text-sm font-semibold text-platinum/85">Name</label>
            <input
              type="text"
              id="sub-name"
              name="name"
              placeholder="Your name"
              class="block w-full rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white placeholder-cool/60 outline-none transition duration-200 focus:border-teal/50 focus:bg-white/[0.06]"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-pill bg-gradient-accent px-6 py-3 text-sm font-semibold text-ink transition hover:-translate-y-0.5 hover:shadow-glow"
          >
            Subscribe to Briefings →
          </button>
          <p class="text-xs text-cool">
            Unsubscribe at any time. We respect your privacy.
          </p>

          <!-- Success -->
          <p id="sub-success" class="hidden rounded-xl border border-teal/30 bg-teal/5 px-4 py-3 text-sm text-teal" role="status" aria-live="polite">
            You're subscribed. We'll be in touch when the next brief is ready.
          </p>
        </form>
      </div>
    </Container>
  </section>
</BaseLayout>

<script>
  // Category filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('.insight-card');
  const noInsights = document.getElementById('no-insights');
  const resetBtn = document.getElementById('reset-filters');

  let active = 'All';

  function applyFilter() {
    let visible = 0;
    cards.forEach((card) => {
      const match = active === 'All' || card.dataset.category === active;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (noInsights) noInsights.classList.toggle('hidden', visible !== 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      active = btn.dataset.value ?? 'All';
      filterBtns.forEach((b) => {
        const isActive = b.dataset.value === active;
        b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        if (isActive) b.dataset.active = '';
        else delete b.dataset.active;
      });
      applyFilter();
    });
  });

  resetBtn?.addEventListener('click', () => {
    active = 'All';
    filterBtns.forEach((b) => {
      const isAll = b.dataset.value === 'All';
      b.setAttribute('aria-pressed', isAll ? 'true' : 'false');
      if (isAll) b.dataset.active = '';
      else delete b.dataset.active;
    });
    applyFilter();
  });

  // Subscribe form (simulation — wire to real endpoint)
  const subForm = document.getElementById('subscribe-form') as HTMLFormElement | null;
  const subSuccess = document.getElementById('sub-success');

  subForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = subForm.querySelector<HTMLInputElement>('[name="email"]');
    if (!emailInput?.value || !emailInput.validity.valid) {
      emailInput?.focus();
      return;
    }
    // Simulate submission — replace with fetch to your endpoint
    await new Promise((r) => setTimeout(r, 400));
    subForm.querySelectorAll('input, button').forEach((el) => ((el as HTMLElement).style.opacity = '0.4'));
    if (subSuccess) subSuccess.classList.remove('hidden');
  });
</script>
