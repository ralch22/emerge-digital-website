<!-- VSL player: reads data-video off #vslFrame; supports files and embeds -->
<script is:inline>
  (function(){
    var f = document.getElementById('vslFrame');
    var btn = document.getElementById('vslBtn');
    if(!f || !btn) return;
    btn.addEventListener('click', function(){
      var url = (f.getAttribute('data-video') || '').trim();
      if(!url){
        var cap = document.getElementById('vslCap');
        if(cap){ cap.textContent = 'Walkthrough coming shortly — book your call below.'; }
        return;
      }
      var isFile = /\.(mp4|webm|ogv|ogg)(\?|#|$)/i.test(url);
      var media;
      if(isFile){
        media = document.createElement('video');
        media.src = url; media.controls = true; media.autoplay = true;
        media.playsInline = true; media.preload = 'metadata';
      } else {
        var sep = url.indexOf('?') > -1 ? '&' : '?';
        media = document.createElement('iframe');
        media.src = url + sep + 'autoplay=1';
        media.setAttribute('allow', 'autoplay; fullscreen; picture-in-picture; encrypted-media');
        media.setAttribute('allowfullscreen', '');
        media.setAttribute('title', 'Demand generation walkthrough video');
      }
      f.innerHTML = '';
      f.appendChild(media);
    });
  })();
</script>

